---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import CTA from '../components/CTA.astro';
import About from '../components/About.astro';
import Footer from '../components/Footer.astro';
import { site } from '../config';

const highlights = site.highlights.items;
const iconMap = site.icons.highlights;
---

<Layout page={{ title: '首页', description: site.description }}>
	<Header />
	<main>
		<Hero />

		<section class="highlights section">
			<div class="container">
				<div class="section-header animate-on-scroll">
					<span class="section-tag" data-i18n="highlights.header.tag">{site.highlights.header.tag}</span>
					<h2 data-i18n="highlights.header.title">{site.highlights.header.title}</h2>
					{site.highlights.header.subtitle && <p data-i18n="highlights.header.subtitle">{site.highlights.header.subtitle}</p>}
				</div>
				<div class="highlights-grid">
					{highlights.map((h, i) => (
						<a href={h.href} class={`highlight-card animate-on-scroll delay-${i + 1}`}>
							<div class="highlight-icon" set:html={`<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">${iconMap[h.icon]}</svg>`}></div>
							<h3 data-i18n={`highlights.items.${i}.title`}>{h.title}</h3>
							<p data-i18n={`highlights.items.${i}.desc`}>{h.desc}</p>
							<span class="highlight-link" data-i18n="highlights.linkText">{site.highlights.linkText}</span>
						</a>
					))}
				</div>
			</div>
		</section>

		<About />
		<CTA />
	</main>
	<Footer />
</Layout>

<style>
	.highlights {
		background: var(--color-bg-secondary);
	}

	.section-header {
		text-align: center;
		margin-bottom: 56px;
	}

	.section-tag {
		display: inline-block;
		font-size: 12px;
		letter-spacing: 0.15em;
		color: var(--color-text-tertiary);
		margin-bottom: 16px;
		text-transform: uppercase;
	}

	.section-header h2 {
		font-size: clamp(28px, 3.5vw, 40px);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin-bottom: 12px;
	}

	.section-header p {
		font-size: 16px;
		color: var(--color-text-secondary);
	}

	.highlights-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 28px;
	}

	.highlight-card {
		display: block;
		padding: 44px 32px;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		background: var(--color-card-bg-gradient);
		transition: border-color var(--transition-fast), box-shadow var(--transition-fast), transform var(--transition-fast);
		position: relative;
		overflow: hidden;
	}

	.highlight-card::before {
		content: "";
		position: absolute;
		top: -50%;
		right: -50%;
		width: 200%;
		height: 200%;
		background: radial-gradient(circle at 80% 20%, var(--card-accent, var(--color-card-glow)) 0%, transparent 55%);
		opacity: 0;
		transition: opacity var(--transition-slow);
		pointer-events: none;
	}

	.highlight-card::after {
		content: "";
		position: absolute;
		top: 0;
		right: 0;
		width: 2px;
		height: 100%;
		background: var(--card-accent-line, var(--color-highlight));
		opacity: 0;
		transition: opacity var(--transition-fast);
	}

	.highlight-card:nth-child(1) { --card-accent: rgba(59, 130, 246, 0.08); --card-accent-line: #3b82f6; }
	.highlight-card:nth-child(2) { --card-accent: rgba(139, 92, 246, 0.08); --card-accent-line: #8b5cf6; }
	.highlight-card:nth-child(3) { --card-accent: rgba(6, 182, 212, 0.08); --card-accent-line: #06b6d4; }

	.highlight-card:hover {
		border-color: var(--card-accent-line, var(--color-text));
		box-shadow: 0 12px 40px var(--color-card-shadow-hover);
		transform: translateY(-4px);
	}

	.highlight-card:hover::before {
		opacity: 1;
	}

	.highlight-card:hover::after {
		opacity: 1;
	}

	.highlight-icon {
		width: 52px;
		height: 52px;
		display: flex;
		align-items: center;
		justify-content: center;
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		margin-bottom: 22px;
		color: var(--color-text);
		background: var(--color-bg-tertiary);
		transition: border-color var(--transition-fast), box-shadow var(--transition-fast), color var(--transition-fast), transform var(--transition-fast);
		position: relative;
		z-index: 1;
	}

	.highlight-card:hover .highlight-icon {
		border-color: var(--card-accent-line, var(--color-highlight));
		box-shadow: 0 4px 16px var(--card-accent, var(--color-card-glow));
		color: var(--card-accent-line, var(--color-highlight));
		transform: scale(1.05);
	}

	.highlight-card h3 {
		font-size: 18px;
		font-weight: 600;
		margin-bottom: 8px;
		letter-spacing: -0.01em;
	}

	.highlight-card p {
		font-size: 14px;
		line-height: 1.7;
		color: var(--color-text-secondary);
		margin-bottom: 16px;
	}

	.highlight-link {
		font-size: 13px;
		font-weight: 500;
		color: var(--color-text-tertiary);
		transition: color var(--transition-fast);
	}

	.highlight-card:hover .highlight-link {
		color: var(--color-text);
	}

	@media (max-width: 900px) {
		.highlights-grid {
			grid-template-columns: 1fr;
			max-width: 480px;
			margin: 0 auto;
		}
	}
</style>
