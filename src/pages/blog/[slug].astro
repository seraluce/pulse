---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map(post => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = (await getCollection('blog')).sort(
	(a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

const currentIndex = allPosts.findIndex(p => p.id === post.id);
const prevPost = allPosts[currentIndex + 1];
const nextPost = allPosts[currentIndex - 1];
---

<Layout page={{
	title: post.data.title,
	path: `/blog/${post.id}`,
	description: post.data.description,
	image: `/og/${post.id}`,
}}>
	<Header />
	<main>
		<article class="blog-post">
			<header class="post-header">
				<div class="container">
					<a href="/blog" class="post-back">← 返回博客</a>
					<div class="post-meta">
						<time datetime={post.data.pubDate.toISOString()}>
							{post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'numeric', day: 'numeric' }).replace(/-/g, '/')}
						</time>
						<span class="post-author">{post.data.author}</span>
					</div>
					<h1>{post.data.title}</h1>
					<p class="post-desc">{post.data.description}</p>
					{post.data.tags.length > 0 && (
						<div class="post-tags">
							{post.data.tags.map(tag => (
								<span class="post-tag">{tag}</span>
							))}
						</div>
					)}
				</div>
				<div class="post-cover">
					<img src={`/cover/${post.id}`} alt={post.data.title} />
				</div>
			</header>

			<div class="container">
				<div class="post-content">
					<Content />
				</div>

				<nav class="post-nav">
					{prevPost && (
						<a href={`/blog/${prevPost.id}`} class="post-nav-link prev">
							<span class="post-nav-label">← 上一篇</span>
							<span class="post-nav-title">{prevPost.data.title}</span>
						</a>
					)}
					{nextPost && (
						<a href={`/blog/${nextPost.id}`} class="post-nav-link next">
							<span class="post-nav-label">下一篇 →</span>
							<span class="post-nav-title">{nextPost.data.title}</span>
						</a>
					)}
				</nav>
			</div>
		</article>
	</main>
	<Footer />
</Layout>

<style>
	.blog-post {
		padding-top: var(--header-height);
		padding-bottom: 80px;
	}

	.post-header {
		padding-top: 56px;
		padding-bottom: 48px;
		margin-bottom: 0;
		position: relative;
	}

	.post-header::before {
		content: "";
		position: absolute;
		top: -20%;
		left: 50%;
		transform: translateX(-50%);
		width: 90%;
		height: 120%;
		background: 
			radial-gradient(ellipse 60% 50% at 40% 40%, var(--gradient-aurora-1) 0%, transparent 70%),
			radial-gradient(ellipse 50% 45% at 65% 55%, var(--gradient-aurora-2) 0%, transparent 70%),
			radial-gradient(ellipse 40% 40% at 50% 60%, var(--gradient-aurora-3) 0%, transparent 75%);
		pointer-events: none;
		opacity: 0.9;
		z-index: 0;
		filter: blur(40px);
	}

	.post-header .container {
		position: relative;
		z-index: 1;
	}

	.post-back {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-size: 13px;
		color: var(--color-text-secondary);
		margin-bottom: 28px;
		transition: color var(--transition-fast), transform var(--transition-fast);
		text-decoration: none;
		padding: 6px 12px;
		border: 1px solid var(--color-border);
		border-radius: 100px;
		background: var(--color-card-bg);
		backdrop-filter: blur(8px);
	}

	.post-back:hover {
		color: var(--color-highlight);
		border-color: var(--color-highlight);
		transform: translateX(-2px);
	}

	.post-meta {
		display: flex;
		align-items: center;
		gap: 16px;
		margin-bottom: 20px;
		flex-wrap: wrap;
	}

	.post-meta time {
		font-size: 13px;
		color: var(--color-text-secondary);
		padding: 4px 10px;
		border: 1px solid var(--color-border);
		border-radius: 100px;
		background: var(--color-card-bg);
	}

	.post-author {
		font-size: 13px;
		color: var(--color-text-secondary);
		display: flex;
		align-items: center;
		gap: 8px;
	}

	.post-author::before {
		content: "";
		width: 4px;
		height: 4px;
		border-radius: 50%;
		background: var(--color-text-tertiary);
	}

	.post-header h1 {
		font-size: clamp(28px, 4vw, 42px);
		font-weight: 700;
		letter-spacing: -0.03em;
		line-height: 1.25;
		margin-bottom: 18px;
		max-width: 760px;
		background: linear-gradient(135deg, var(--color-text) 0%, var(--color-text-secondary) 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.post-desc {
		font-size: 17px;
		line-height: 1.7;
		color: var(--color-text-secondary);
		margin-bottom: 24px;
		max-width: 720px;
	}

	.post-tags {
		display: flex;
		gap: 8px;
		flex-wrap: wrap;
	}

	.post-tag {
		font-size: 12px;
		padding: 5px 12px;
		border-radius: 100px;
		border: 1px solid var(--color-border);
		color: var(--color-text-secondary);
		background: var(--color-card-bg);
		transition: all var(--transition-fast);
	}

	.post-tag:hover {
		border-color: var(--color-highlight);
		color: var(--color-highlight);
		background: var(--color-card-glow);
	}

	/* 封面图 */
	.post-cover {
		margin-top: 48px;
		max-width: 960px;
		margin-left: auto;
		margin-right: auto;
		position: relative;
	}

	.post-cover::before {
		content: "";
		position: absolute;
		inset: -1px;
		border-radius: var(--radius-lg);
		padding: 1px;
		background: linear-gradient(135deg, var(--gradient-aurora-1), var(--gradient-aurora-2), var(--gradient-aurora-3));
		-webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
		mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
		-webkit-mask-composite: xor;
		mask-composite: exclude;
		opacity: 0.6;
		pointer-events: none;
	}

	.post-cover img {
		width: 100%;
		height: auto;
		border-radius: var(--radius-lg);
		object-fit: cover;
		max-height: 480px;
		box-shadow: 0 20px 60px var(--color-card-shadow-hover);
	}

	/* 文章正文样式 */
	.post-content {
		max-width: 720px;
		margin: 0 auto;
		font-size: 16px;
		line-height: 1.85;
		color: var(--color-text);
	}

	.post-content :global(h2) {
		font-size: 24px;
		font-weight: 700;
		letter-spacing: -0.02em;
		margin-top: 56px;
		margin-bottom: 18px;
		position: relative;
		padding-left: 16px;
	}

	.post-content :global(h2::before) {
		content: "";
		position: absolute;
		left: 0;
		top: 0.3em;
		bottom: 0.3em;
		width: 3px;
		border-radius: 2px;
		background: linear-gradient(180deg, var(--color-highlight), var(--color-highlight-secondary));
	}

	.post-content :global(h3) {
		font-size: 19px;
		font-weight: 600;
		margin-top: 36px;
		margin-bottom: 14px;
	}

	.post-content :global(p) {
		margin-bottom: 22px;
	}

	.post-content :global(a) {
		color: var(--color-highlight);
		text-decoration: none;
		border-bottom: 1px solid rgba(59, 130, 246, 0.3);
		transition: all var(--transition-fast);
	}

	.post-content :global(a:hover) {
		border-bottom-color: var(--color-highlight);
		opacity: 0.85;
	}

	.post-content :global(ul),
	.post-content :global(ol) {
		margin-bottom: 22px;
		padding-left: 28px;
	}

	.post-content :global(li) {
		margin-bottom: 10px;
		position: relative;
	}

	.post-content :global(ul li::marker) {
		color: var(--color-highlight);
	}

	.post-content :global(blockquote) {
		border-left: none;
		padding: 24px 28px;
		margin: 32px 0;
		color: var(--color-text-secondary);
		font-style: italic;
		background: var(--color-card-bg-gradient);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		position: relative;
	}

	.post-content :global(blockquote::before) {
		content: '"';
		position: absolute;
		top: 8px;
		left: 14px;
		font-size: 48px;
		font-family: Georgia, serif;
		line-height: 1;
		color: var(--color-highlight);
		opacity: 0.2;
	}

	.post-content :global(code) {
		font-size: 14px;
		padding: 2px 8px;
		background: var(--color-bg-secondary);
		border: 1px solid var(--color-border);
		border-radius: 6px;
		font-family: 'SF Mono', 'Fira Code', 'JetBrains Mono', monospace;
		color: var(--color-highlight);
	}

	.post-content :global(pre) {
		margin-bottom: 28px;
		padding: 24px;
		background: linear-gradient(135deg, var(--color-bg-secondary) 0%, var(--color-bg-tertiary) 100%);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		overflow-x: auto;
		box-shadow: 0 4px 16px var(--color-card-shadow);
	}

	.post-content :global(pre code) {
		padding: 0;
		background: none;
		border: none;
		color: var(--color-text);
	}

	.post-content :global(table) {
		width: 100%;
		margin-bottom: 28px;
		border-collapse: separate;
		border-spacing: 0;
		font-size: 14px;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		overflow: hidden;
	}

	.post-content :global(th),
	.post-content :global(td) {
		padding: 12px 18px;
		border-bottom: 1px solid var(--color-border);
		text-align: left;
	}

	.post-content :global(th) {
		font-weight: 600;
		background: var(--color-bg-secondary);
	}

	.post-content :global(tr:last-child td) {
		border-bottom: none;
	}

	.post-content :global(hr) {
		border: none;
		height: 1px;
		margin: 48px 0;
		background: linear-gradient(90deg, transparent, var(--color-border), transparent);
	}

	.post-content :global(strong) {
		font-weight: 600;
		color: var(--color-text);
	}

	.post-content :global(img) {
		max-width: 100%;
		height: auto;
		border-radius: var(--radius-lg);
		margin: 28px 0;
		box-shadow: 0 8px 32px var(--color-card-shadow);
		border: 1px solid var(--color-border);
	}

	/* 上下篇导航 */
	.post-nav {
		max-width: 720px;
		margin: 72px auto 0;
		padding-top: 40px;
		border-top: 1px solid var(--color-border);
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 20px;
	}

	.post-nav-link {
		display: flex;
		flex-direction: column;
		gap: 8px;
		padding: 24px 20px;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		text-decoration: none;
		background: var(--color-card-bg-gradient);
		transition: all var(--transition-fast);
		position: relative;
		overflow: hidden;
	}

	.post-nav-link::before {
		content: "";
		position: absolute;
		top: -50%;
		right: -50%;
		width: 200%;
		height: 200%;
		background: radial-gradient(circle, var(--color-card-glow) 0%, transparent 60%);
		opacity: 0;
		transition: opacity var(--transition-slow);
		pointer-events: none;
	}

	.post-nav-link:hover {
		border-color: var(--color-highlight);
		transform: translateY(-2px);
		box-shadow: 0 8px 32px var(--color-card-shadow-hover);
	}

	.post-nav-link:hover::before {
		opacity: 1;
	}

	.post-nav-link.next {
		text-align: right;
		align-items: flex-end;
	}

	.post-nav-label {
		font-size: 12px;
		color: var(--color-text-tertiary);
		font-weight: 500;
		letter-spacing: 0.02em;
	}

	.post-nav-title {
		font-size: 15px;
		font-weight: 500;
		color: var(--color-text);
		line-height: 1.5;
		position: relative;
		z-index: 1;
	}

	@media (max-width: 768px) {
		.post-header {
			padding-top: 40px;
			padding-bottom: 32px;
		}
		.post-nav {
			grid-template-columns: 1fr;
		}
		.post-nav-link.next {
			text-align: left;
			align-items: flex-start;
		}
		.post-cover {
			margin-top: 32px;
		}
		.post-cover img {
			border-radius: var(--radius);
			max-height: 280px;
		}
		.post-header h1 {
			font-size: 28px;
		}
	}

	@media (max-width: 480px) {
		.container {
			padding-left: 20px;
			padding-right: 20px;
		}
		.post-content {
			font-size: 15px;
		}
		.post-content :global(h2) {
			font-size: 20px;
		}
		.post-header h1 {
			font-size: 24px;
		}
		.post-desc {
			font-size: 15px;
		}
	}
</style>
