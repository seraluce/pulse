---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map(post => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = (await getCollection('blog')).sort(
	(a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

const currentIndex = allPosts.findIndex(p => p.id === post.id);
const prevPost = allPosts[currentIndex + 1];
const nextPost = allPosts[currentIndex - 1];
---

<Layout page={{
	title: post.data.title,
	path: `/blog/${post.slug}`,
	description: post.data.description,
}}>
	<Header />
	<main>
		<article class="blog-post">
			<div class="container">
				<header class="post-header">
					<a href="/blog" class="post-back">← 返回博客</a>
					<div class="post-meta">
						<time datetime={post.data.pubDate.toISOString()}>
							{post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
						</time>
						<span class="post-author">{post.data.author}</span>
					</div>
					<h1>{post.data.title}</h1>
					<p class="post-desc">{post.data.description}</p>
					{post.data.tags.length > 0 && (
						<div class="post-tags">
							{post.data.tags.map(tag => (
								<span class="post-tag">{tag}</span>
							))}
						</div>
					)}
				</header>

				<div class="post-content">
					<Content />
				</div>

				<nav class="post-nav">
					{prevPost && (
						<a href={`/blog/${prevPost.slug}`} class="post-nav-link prev">
							<span class="post-nav-label">← 上一篇</span>
							<span class="post-nav-title">{prevPost.data.title}</span>
						</a>
					)}
					{nextPost && (
						<a href={`/blog/${nextPost.slug}`} class="post-nav-link next">
							<span class="post-nav-label">下一篇 →</span>
							<span class="post-nav-title">{nextPost.data.title}</span>
						</a>
					)}
				</nav>
			</div>
		</article>
	</main>
	<Footer />
</Layout>

<style>
	.blog-post {
		padding-top: calc(var(--header-height) + 60px);
		padding-bottom: 80px;
	}

	.post-header {
		max-width: 720px;
		margin: 0 auto 48px;
	}

	.post-back {
		display: inline-block;
		font-size: 13px;
		color: var(--color-text-tertiary);
		margin-bottom: 24px;
		transition: color var(--transition-fast);
		text-decoration: none;
	}

	.post-back:hover {
		color: var(--color-text);
	}

	.post-meta {
		display: flex;
		align-items: center;
		gap: 16px;
		margin-bottom: 16px;
	}

	.post-meta time {
		font-size: 13px;
		color: var(--color-text-tertiary);
	}

	.post-author {
		font-size: 13px;
		color: var(--color-text-tertiary);
	}

	.post-author::before {
		content: '·';
		margin-right: 16px;
	}

	.post-header h1 {
		font-size: clamp(28px, 4vw, 40px);
		font-weight: 700;
		letter-spacing: -0.03em;
		line-height: 1.3;
		margin-bottom: 16px;
	}

	.post-desc {
		font-size: 17px;
		line-height: 1.7;
		color: var(--color-text-secondary);
		margin-bottom: 20px;
	}

	.post-tags {
		display: flex;
		gap: 8px;
		flex-wrap: wrap;
	}

	.post-tag {
		font-size: 12px;
		padding: 3px 10px;
		border-radius: 100px;
		border: 1px solid var(--color-border);
		color: var(--color-text-tertiary);
	}

	/* 文章正文样式 */
	.post-content {
		max-width: 720px;
		margin: 0 auto;
		font-size: 16px;
		line-height: 1.8;
		color: var(--color-text);
	}

	.post-content :global(h2) {
		font-size: 24px;
		font-weight: 700;
		letter-spacing: -0.02em;
		margin-top: 48px;
		margin-bottom: 16px;
	}

	.post-content :global(h3) {
		font-size: 18px;
		font-weight: 600;
		margin-top: 32px;
		margin-bottom: 12px;
	}

	.post-content :global(p) {
		margin-bottom: 20px;
	}

	.post-content :global(a) {
		color: var(--color-text);
		text-decoration: underline;
		text-underline-offset: 3px;
	}

	.post-content :global(a:hover) {
		opacity: 0.7;
	}

	.post-content :global(ul),
	.post-content :global(ol) {
		margin-bottom: 20px;
		padding-left: 24px;
	}

	.post-content :global(li) {
		margin-bottom: 8px;
	}

	.post-content :global(blockquote) {
		border-left: 3px solid var(--color-border);
		padding-left: 20px;
		margin: 24px 0;
		color: var(--color-text-secondary);
		font-style: italic;
	}

	.post-content :global(code) {
		font-size: 14px;
		padding: 2px 6px;
		background: var(--color-bg-secondary);
		border: 1px solid var(--color-border);
		border-radius: 4px;
		font-family: 'SF Mono', 'Fira Code', monospace;
	}

	.post-content :global(pre) {
		margin-bottom: 24px;
		padding: 20px;
		background: var(--color-bg-secondary);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		overflow-x: auto;
	}

	.post-content :global(pre code) {
		padding: 0;
		background: none;
		border: none;
	}

	.post-content :global(table) {
		width: 100%;
		margin-bottom: 24px;
		border-collapse: collapse;
		font-size: 14px;
	}

	.post-content :global(th),
	.post-content :global(td) {
		padding: 10px 16px;
		border: 1px solid var(--color-border);
		text-align: left;
	}

	.post-content :global(th) {
		font-weight: 600;
		background: var(--color-bg-secondary);
	}

	.post-content :global(hr) {
		border: none;
		border-top: 1px solid var(--color-border);
		margin: 40px 0;
	}

	.post-content :global(strong) {
		font-weight: 600;
	}

	.post-content :global(img) {
		max-width: 100%;
		height: auto;
		border-radius: var(--radius);
		margin: 24px 0;
	}

	/* 上下篇导航 */
	.post-nav {
		max-width: 720px;
		margin: 60px auto 0;
		padding-top: 32px;
		border-top: 1px solid var(--color-border);
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 24px;
	}

	.post-nav-link {
		display: flex;
		flex-direction: column;
		gap: 4px;
		padding: 16px;
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		text-decoration: none;
		transition: border-color var(--transition-fast);
	}

	.post-nav-link:hover {
		border-color: var(--color-text);
	}

	.post-nav-link.next {
		text-align: right;
	}

	.post-nav-label {
		font-size: 12px;
		color: var(--color-text-tertiary);
	}

	.post-nav-title {
		font-size: 14px;
		font-weight: 500;
		color: var(--color-text);
	}

	@media (max-width: 768px) {
		.post-nav {
			grid-template-columns: 1fr;
		}
		.post-nav-link.next {
			text-align: left;
		}
	}

	@media (max-width: 480px) {
		.post-content {
			font-size: 15px;
		}
		.post-content :global(h2) {
			font-size: 20px;
		}
	}
</style>
