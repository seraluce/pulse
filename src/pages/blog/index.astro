---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);
---

<Layout page={{ title: '博客', path: '/blog', description: 'Grateful Group 博客，分享企业咨询、数字化转型、品牌建设、数据驱动等领域的专业洞察和实战经验。' }}>
	<Header />
	<main>
		<section class="page-hero">
			<div class="container">
				<span class="section-tag animate-on-scroll">BLOG</span>
				<h1 class="animate-on-scroll delay-1">博客与洞察</h1>
				<p class="animate-on-scroll delay-2">专业观点、行业趋势、实战方法论</p>
			</div>
		</section>

		<section class="blog-list section">
			<div class="container">
				<div class="blog-grid">
					{posts.map((post) => (
						<a href={`/blog/${post.id}`} class="blog-card animate-on-scroll" title={post.data.title}>
							<div class="blog-card-cover">
								<img src={`/cover/${post.id}`} alt={post.data.title} />
							</div>
							<div class="blog-card-body">
								<h2 class="blog-card-title">{post.data.title}</h2>
								<div class="blog-card-meta">
									<time datetime={post.data.pubDate.toISOString()}>
										{post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'numeric', day: 'numeric' }).replace(/-/g, '/')}
									</time>
									{post.data.tags.length > 0 && (
										<div class="blog-tags">
											{post.data.tags.map(tag => (
												<span class="blog-tag">{tag}</span>
											))}
										</div>
									)}
								</div>
							</div>
						</a>
					))}
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>

<style>
	.page-hero {
		padding-top: calc(var(--header-height) + 80px);
		padding-bottom: 60px;
		text-align: center;
	}

	.section-tag {
		display: inline-block;
		font-size: 12px;
		letter-spacing: 0.15em;
		color: var(--color-text-tertiary);
		margin-bottom: 16px;
		text-transform: uppercase;
	}

	.page-hero h1 {
		font-size: clamp(32px, 4.5vw, 48px);
		font-weight: 700;
		letter-spacing: -0.03em;
		margin-bottom: 16px;
	}

	.page-hero p {
		font-size: 17px;
		color: var(--color-text-secondary);
		max-width: 520px;
		margin: 0 auto;
		line-height: 1.7;
	}

	.blog-list {
		padding-bottom: 80px;
	}

	.blog-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 28px;
		max-width: 1140px;
		margin: 0 auto;
	}

	.blog-card {
		position: relative;
		display: flex;
		flex-direction: column;
		background: var(--color-card-bg-gradient);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		transition: all var(--transition-fast);
		text-decoration: none;
		color: inherit;
		overflow: hidden;
	}

	.blog-card::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: radial-gradient(ellipse at 100% 0%, var(--card-accent, var(--color-card-glow)) 0%, transparent 50%);
		opacity: 0;
		transition: opacity var(--transition-slow);
		pointer-events: none;
	}

	.blog-card::after {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 2px;
		background: var(--card-accent-line, var(--color-highlight));
		opacity: 0;
		transition: opacity var(--transition-fast);
	}

	.blog-card:nth-child(1) { --card-accent: rgba(59, 130, 246, 0.1); --card-accent-line: #3b82f6; }
	.blog-card:nth-child(2) { --card-accent: rgba(139, 92, 246, 0.1); --card-accent-line: #8b5cf6; }
	.blog-card:nth-child(3) { --card-accent: rgba(6, 182, 212, 0.1); --card-accent-line: #06b6d4; }
	.blog-card:nth-child(4) { --card-accent: rgba(245, 158, 11, 0.1); --card-accent-line: #f59e0b; }
	.blog-card:nth-child(5) { --card-accent: rgba(16, 185, 129, 0.1); --card-accent-line: #10b981; }
	.blog-card:nth-child(6) { --card-accent: rgba(236, 72, 153, 0.1); --card-accent-line: #ec4899; }

	.blog-card:hover {
		border-color: var(--card-accent-line, var(--color-text));
		transform: translateY(-4px);
		box-shadow: 0 16px 48px var(--color-card-shadow-hover);
	}

	.blog-card:hover::before {
		opacity: 1;
	}

	.blog-card:hover::after {
		opacity: 1;
	}

	.blog-card-cover {
		width: 100%;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		position: relative;
		z-index: 1;
	}

	.blog-card-cover img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.4s ease;
	}

	.blog-card:hover .blog-card-cover img {
		transform: scale(1.06);
	}

	.blog-card-body {
		padding: 24px 22px 22px;
		display: flex;
		flex-direction: column;
		gap: 12px;
		position: relative;
		z-index: 1;
		flex: 1;
	}

	.blog-card-meta {
		display: flex;
		align-items: center;
		gap: 8px;
		flex-wrap: wrap;
	}

	.blog-card-meta time {
		font-size: 12px;
		color: var(--color-text-tertiary);
	}

	.blog-tags {
		display: flex;
		gap: 6px;
		flex-wrap: wrap;
	}

	.blog-tag {
		font-size: 10px;
		padding: 2px 8px;
		border-radius: 100px;
		border: 1px solid var(--color-border);
		color: var(--color-text-tertiary);
	}

	.blog-card-title {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border-width: 0;
	}

	@media (max-width: 900px) {
		.blog-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 768px) {
		.blog-grid {
			grid-template-columns: 1fr;
		}
		.blog-card-body {
			padding: 20px;
			gap: 12px;
		}
		.blog-card-meta time {
			font-size: 13px;
		}
		.blog-tag {
			font-size: 11px;
			padding: 3px 10px;
		}
		.page-hero {
			padding-bottom: 40px;
		}
	}

	@media (max-width: 480px) {
		.container {
			padding-left: 20px;
			padding-right: 20px;
		}
	}
</style>
