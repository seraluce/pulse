---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);
---

<Layout page={{ title: '博客', path: '/blog', description: 'Grateful Group 博客，分享企业咨询、数字化转型、品牌建设、数据驱动等领域的专业洞察和实战经验。' }}>
	<Header />
	<main>
		<section class="page-hero">
			<div class="container">
				<span class="section-tag animate-on-scroll">BLOG</span>
				<h1 class="animate-on-scroll delay-1">博客与洞察</h1>
				<p class="animate-on-scroll delay-2">专业观点、行业趋势、实战方法论</p>
			</div>
		</section>

		<section class="blog-list section">
			<div class="container">
				<div class="blog-grid">
					{posts.map((post) => (
						<a href={`/blog/${post.id}`} class="blog-card animate-on-scroll">
							<div class="blog-card-meta">
								<time datetime={post.data.pubDate.toISOString()}>
									{post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
								</time>
								{post.data.tags.length > 0 && (
									<div class="blog-tags">
										{post.data.tags.map(tag => (
											<span class="blog-tag">{tag}</span>
										))}
									</div>
								)}
							</div>
							<h2 class="blog-card-title">{post.data.title}</h2>
							<p class="blog-card-desc">{post.data.description}</p>
							<span class="blog-card-link">阅读全文 →</span>
						</a>
					))}
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>

<style>
	.page-hero {
		padding-top: calc(var(--header-height) + 80px);
		padding-bottom: 60px;
		text-align: center;
	}

	.section-tag {
		display: inline-block;
		font-size: 12px;
		letter-spacing: 0.15em;
		color: var(--color-text-tertiary);
		margin-bottom: 16px;
		text-transform: uppercase;
	}

	.page-hero h1 {
		font-size: clamp(32px, 4.5vw, 48px);
		font-weight: 700;
		letter-spacing: -0.03em;
		margin-bottom: 16px;
	}

	.page-hero p {
		font-size: 17px;
		color: var(--color-text-secondary);
		max-width: 520px;
		margin: 0 auto;
		line-height: 1.7;
	}

	.blog-list {
		padding-bottom: 80px;
	}

	.blog-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 16px;
		max-width: 900px;
		margin: 0 auto;
	}

	.blog-card {
		display: block;
		padding: 32px;
		background: var(--color-card-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		transition: border-color var(--transition-fast), transform var(--transition-fast);
		text-decoration: none;
		color: inherit;
	}

	.blog-card:hover {
		border-color: var(--color-text);
		transform: translateY(-2px);
	}

	.blog-card-meta {
		display: flex;
		align-items: center;
		gap: 12px;
		margin-bottom: 12px;
		flex-wrap: wrap;
	}

	.blog-card-meta time {
		font-size: 13px;
		color: var(--color-text-tertiary);
	}

	.blog-tags {
		display: flex;
		gap: 6px;
		flex-wrap: wrap;
	}

	.blog-tag {
		font-size: 11px;
		padding: 2px 8px;
		border-radius: 100px;
		border: 1px solid var(--color-border);
		color: var(--color-text-tertiary);
	}

	.blog-card-title {
		font-size: 18px;
		font-weight: 600;
		letter-spacing: -0.02em;
		margin-bottom: 8px;
		line-height: 1.4;
	}

	.blog-card-desc {
		font-size: 14px;
		line-height: 1.7;
		color: var(--color-text-secondary);
		margin-bottom: 16px;
	}

	.blog-card-link {
		font-size: 13px;
		color: var(--color-text-tertiary);
		transition: color var(--transition-fast);
	}

	.blog-card:hover .blog-card-link {
		color: var(--color-text);
	}

	@media (max-width: 768px) {
		.blog-grid {
			grid-template-columns: 1fr;
		}
		.page-hero {
			padding-bottom: 40px;
		}
	}

	@media (max-width: 480px) {
		.blog-card {
			padding: 24px;
		}
	}
</style>
