---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout page={{ title: '页面未找到' }}>
	<Header />
	<div class="error-404">
		<div class="orb orb-1"></div>
		<div class="orb orb-2"></div>
		<div class="container">
			<div class="error-content">
				<div class="error-code">
					<span class="num">4</span>
					<span class="divider">
						<svg viewBox="0 0 4 80" fill="none">
							<rect width="4" height="80" rx="2" fill="currentColor"/>
						</svg>
					</span>
					<span class="num">0</span>
					<span class="divider">
						<svg viewBox="0 0 4 80" fill="none">
							<rect width="4" height="80" rx="2" fill="currentColor"/>
						</svg>
					</span>
					<span class="num">4</span>
				</div>
				<h1>页面不存在</h1>
				<p>您访问的页面不存在或已被移除</p>
				<div class="actions">
					<a href="/" class="btn-primary">返回首页</a>
					<a href="/contact" class="btn-secondary">联系我们</a>
				</div>
			</div>
		</div>
	</div>
	<Footer />
</Layout>

<style>
	.error-404 {
		padding: 140px 0 100px;
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
		overflow: hidden;
		min-height: calc(100dvh - var(--header-height));
	}

	.orb {
		position: absolute;
		border-radius: 50%;
		pointer-events: none;
	}

	.orb-1 {
		width: 480px;
		height: 480px;
		background: radial-gradient(circle, rgba(59, 130, 246, 0.12) 0%, transparent 60%);
		top: -120px;
		right: -80px;
	}

	.orb-2 {
		width: 400px;
		height: 400px;
		background: radial-gradient(circle, rgba(139, 92, 246, 0.1) 0%, transparent 60%);
		bottom: -100px;
		left: -80px;
	}

	:root.dark .orb-1 {
		background: radial-gradient(circle, rgba(59, 130, 246, 0.18) 0%, transparent 60%);
	}
	:root.dark .orb-2 {
		background: radial-gradient(circle, rgba(139, 92, 246, 0.15) 0%, transparent 60%);
	}

	.error-content {
		text-align: center;
		position: relative;
		z-index: 1;
	}

	.error-code {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 20px;
		margin-bottom: 32px;
	}

	.num {
		font-size: clamp(96px, 16vw, 180px);
		font-weight: 700;
		line-height: 1;
		color: var(--color-text);
		opacity: 0.06;
		letter-spacing: -0.04em;
		user-select: none;
	}

	.divider {
		width: 4px;
		height: 72px;
		color: var(--color-highlight);
		opacity: 0.4;
	}

	.divider svg {
		width: 100%;
		height: 100%;
		display: block;
	}

	h1 {
		font-size: clamp(22px, 3.5vw, 32px);
		font-weight: 600;
		color: var(--color-text);
		margin-bottom: 10px;
		letter-spacing: -0.02em;
	}

	p {
		font-size: 15px;
		color: var(--color-text-secondary);
		margin-bottom: 0;
	}

	.actions {
		display: flex;
		gap: 14px;
		justify-content: center;
		margin-top: 36px;
	}

	.btn-primary,
	.btn-secondary {
		display: inline-flex;
		align-items: center;
		padding: 12px 28px;
		font-size: 14px;
		font-weight: 500;
		border-radius: var(--radius);
		transition: all var(--transition-fast);
	}

	.btn-primary {
		background: var(--color-accent);
		color: var(--color-bg);
	}

	.btn-primary:hover {
		background: var(--color-accent-hover);
		transform: translateY(-1px);
	}

	.btn-secondary {
		background: transparent;
		color: var(--color-text);
		border: 1px solid var(--color-border);
	}

	.btn-secondary:hover {
		background: var(--color-bg-secondary);
		transform: translateY(-1px);
	}

	@media (max-width: 480px) {
		.error-404 {
			padding: 120px 0 80px;
		}

		.error-code {
			gap: 14px;
		}

		.divider {
			height: 54px;
		}

		.actions {
			flex-direction: column;
			padding: 0 32px;
		}

		.btn-primary,
		.btn-secondary {
			width: 100%;
			justify-content: center;
		}
	}
</style>
