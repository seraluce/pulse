---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../config';

const pageCfg = site.pages.contact;
const iconSvg = site.icons.contact;
const faq = pageCfg.faq;
---

<Layout page={{ title: pageCfg.pageHero.title, path: '/contact', description: site.description }}>
	<Header />
	<main>
		<section class="page-hero">
			<div class="container">
				<span class="section-tag animate-on-scroll">{pageCfg.pageHero.tag}</span>
				<h1 class="animate-on-scroll delay-1">{pageCfg.pageHero.title}</h1>
				<p class="animate-on-scroll delay-2">{pageCfg.pageHero.subtitle}</p>
			</div>
		</section>

		<section class="contact section">
			<div class="container">
				<div class="contact-grid">
					<div class="contact-info animate-on-scroll">
						<h2>{pageCfg.infoTitle}</h2>
						<p class="contact-desc">{pageCfg.infoDesc}</p>
						<div class="info-list">
							{pageCfg.contactInfo.map((item) => (
								<a href={item.href} class="info-item">
									<div class="info-icon" set:html={`<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">${iconSvg[item.icon]}</svg>`}></div>
									<div>
										<span class="info-label">{item.title}</span>
										<span class="info-value">{item.value}</span>
									</div>
								</a>
							))}
						</div>
					</div>

					<div class="contact-form-wrap animate-on-scroll delay-2">
						<form class="contact-form" id="contactForm" action={site.formEndpoint} method="POST" data-netlify="true" netlify-honeypot="bot-field"
							data-success={pageCfg.successMessage}
							data-fail={pageCfg.failMessage}
							data-required={pageCfg.requiredMessage}
							data-sending={pageCfg.sendingText}
							data-network-error={pageCfg.networkErrorMessage}
						>
							<input type="hidden" name="form-name" value="contact" />
							<p hidden><label>Don't fill this out: <input name="bot-field" /></label></p>
							{pageCfg.formRows.map((row, rowIndex) => (
								<div class={row.length > 1 ? 'form-row' : ''}>
									{row.map((field) => {
										if (field.type === 'select') {
											return (
												<div class="form-group">
													<label for={field.name}>{field.label}</label>
													<select id={field.name} name={field.name}>
														{field.options?.map((opt) => (
															<option value={opt.value}>{opt.label}</option>
														))}
													</select>
												</div>
											);
										}
										if (field.type === 'textarea') {
											return (
												<div class="form-group">
													<label for={field.name}>{field.label}</label>
													<textarea id={field.name} name={field.name} rows={field.rows || 5} placeholder={field.placeholder || ''} data-required={field.required ? '' : undefined}></textarea>
												</div>
											);
										}
										return (
											<div class="form-group">
												<label for={field.name}>{field.label}</label>
												<input type={field.type} id={field.name} name={field.name} placeholder={field.placeholder || ''} data-required={field.required ? '' : undefined} />
											</div>
										);
									})}
								</div>
							))}
							<button type="submit" class="btn-submit">{pageCfg.submitText}</button>
						</form>
					</div>
				</div>
			</div>
		</section>

		<section class="faq section">
			<div class="container">
				<div class="section-header animate-on-scroll">
					<span class="section-tag">{faq.header.tag}</span>
					<h2>{faq.header.title}</h2>
				</div>
				<div class="faq-grid">
					{faq.items.map((item, i) => (
						<div class={`faq-item animate-on-scroll delay-${i + 1}`}>
							<h3>{item.question}</h3>
							<p>{item.answer}</p>
						</div>
					))}
				</div>
			</div>
		</section>
	</main>
	<div class="form-toast" id="formToast"></div>
	<Footer />
</Layout>

<style>
	.page-hero {
		padding-top: calc(var(--header-height) + 80px);
		padding-bottom: 80px;
		text-align: center;
	}

	.section-tag {
		display: inline-block;
		font-size: 12px;
		letter-spacing: 0.15em;
		color: var(--color-text-tertiary);
		margin-bottom: 16px;
		text-transform: uppercase;
	}

	.page-hero h1 {
		font-size: clamp(32px, 4.5vw, 48px);
		font-weight: 700;
		letter-spacing: -0.03em;
		margin-bottom: 16px;
	}

	.page-hero p {
		font-size: 17px;
		color: var(--color-text-secondary);
		max-width: 520px;
		margin: 0 auto;
		line-height: 1.7;
	}

	.contact { background: var(--color-bg); }

	.contact-grid {
		display: grid;
		grid-template-columns: 1fr 1.2fr;
		gap: 60px;
		align-items: start;
	}

	.contact-info h2 {
		font-size: clamp(24px, 3vw, 32px);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin-bottom: 16px;
	}

	.contact-desc {
		font-size: 15px;
		line-height: 1.7;
		color: var(--color-text-secondary);
		margin-bottom: 32px;
	}

	.info-list {
		display: flex;
		flex-direction: column;
		gap: 12px;
	}

	.info-item {
		display: flex;
		align-items: center;
		gap: 16px;
		padding: 16px;
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		background: var(--color-card-bg-gradient);
		transition: border-color var(--transition-fast), box-shadow var(--transition-fast), transform var(--transition-fast);
	}

	.info-item:hover {
		border-color: var(--color-text);
		box-shadow: 0 4px 16px var(--color-card-shadow-hover);
		transform: translateX(4px);
	}

	.info-icon {
		width: 40px;
		height: 40px;
		display: flex;
		align-items: center;
		justify-content: center;
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		color: var(--color-text);
		background: var(--color-bg-tertiary);
		flex-shrink: 0;
		transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
	}

	.info-item:hover .info-icon {
		border-color: var(--color-highlight);
		box-shadow: 0 2px 12px var(--color-card-glow);
	}

	.info-label {
		display: block;
		font-size: 12px;
		color: var(--color-text-tertiary);
		margin-bottom: 2px;
	}

	.info-value {
		display: block;
		font-size: 14px;
		font-weight: 500;
		color: var(--color-text);
	}

	.contact-form-wrap {
		background: var(--color-card-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		padding: 40px;
	}

	.form-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 16px;
	}

	.form-group {
		margin-bottom: 20px;
	}

	.form-group label {
		display: block;
		font-size: 13px;
		font-weight: 500;
		color: var(--color-text);
		margin-bottom: 6px;
	}

	.form-group input,
	.form-group select,
	.form-group textarea {
		width: 100%;
		padding: 10px 14px;
		font-size: 14px;
		font-family: inherit;
		color: var(--color-text);
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		outline: none;
		transition: border-color var(--transition-fast);
	}

	.form-group input:focus,
	.form-group select:focus,
	.form-group textarea:focus {
		border-color: var(--color-text);
	}

	.form-group input.error,
	.form-group select.error,
	.form-group textarea.error {
		border-color: #ef4444;
		animation: shake 0.4s ease;
	}

	@keyframes shake {
		0%, 100% { transform: translateX(0); }
		20%, 60% { transform: translateX(-6px); }
		40%, 80% { transform: translateX(6px); }
	}

	/* 提交反馈 */
	.form-toast {
		position: fixed;
		top: 100px;
		left: 50%;
		transform: translateX(-50%) translateY(-20px);
		padding: 14px 28px;
		border-radius: var(--radius);
		font-size: 14px;
		font-weight: 500;
		opacity: 0;
		visibility: hidden;
		transition: all 0.3s ease;
		z-index: 9999;
		pointer-events: none;
	}

	.form-toast.show {
		opacity: 1;
		visibility: visible;
		transform: translateX(-50%) translateY(0);
	}

	.form-toast.success {
		background: #f0fdf4;
		color: #166534;
		border: 1px solid #bbf7d0;
	}

	.form-toast.fail {
		background: #fef2f2;
		color: #991b1b;
		border: 1px solid #fecaca;
	}

	:root.dark .form-toast.success {
		background: #052e16;
		color: #86efac;
		border-color: #166534;
	}

	:root.dark .form-toast.fail {
		background: #350a0a;
		color: #fca5a5;
		border-color: #991b1b;
	}

	.form-group input::placeholder,
	.form-group textarea::placeholder {
		color: var(--color-text-tertiary);
	}

	.form-group textarea {
		resize: vertical;
		min-height: 120px;
	}

	.form-group select {
		appearance: none;
		background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='%23888' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
		background-repeat: no-repeat;
		background-position: right 14px center;
		padding-right: 36px;
	}

	.btn-submit {
		display: inline-flex;
		align-items: center;
		padding: 12px 28px;
		font-size: 15px;
		font-weight: 500;
		font-family: inherit;
		color: var(--color-bg);
		background: var(--color-accent);
		border: none;
		border-radius: var(--radius);
		cursor: pointer;
		transition: background var(--transition-fast);
	}

	.btn-submit:hover {
		background: var(--color-accent-hover);
	}

	.faq { background: var(--color-bg-secondary); }

	.section-header {
		text-align: center;
		margin-bottom: 48px;
	}

	.section-header h2 {
		font-size: clamp(28px, 3.5vw, 40px);
		font-weight: 700;
		letter-spacing: -0.02em;
	}

	.faq-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 16px;
		max-width: 900px;
		margin: 0 auto;
	}

	.faq-item {
		padding: 28px;
		background: var(--color-card-bg-gradient);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		transition: border-color var(--transition-fast), box-shadow var(--transition-fast), transform var(--transition-fast);
	}

	.faq-item:hover {
		border-color: var(--color-text);
		box-shadow: 0 6px 24px var(--color-card-shadow-hover);
		transform: translateY(-2px);
	}

	.faq-item h3 {
		font-size: 15px;
		font-weight: 600;
		margin-bottom: 8px;
	}

	.faq-item p {
		font-size: 14px;
		line-height: 1.7;
		color: var(--color-text-secondary);
	}

	@media (max-width: 900px) {
		.contact-grid { grid-template-columns: 1fr; gap: 40px; }
		.faq-grid { grid-template-columns: 1fr; }
	}

	@media (max-width: 480px) {
		.form-row { grid-template-columns: 1fr; }
		.contact-form-wrap { padding: 24px; }
	}
</style>

<script>
	const form = document.getElementById('contactForm') as HTMLFormElement;
	const toast = document.getElementById('formToast') as HTMLDivElement;

	if (form && toast) {
		// 输入时清除错误状态
		form.querySelectorAll('input, select, textarea').forEach(el => {
			el.addEventListener('input', () => el.classList.remove('error'));
		});

		form.addEventListener('submit', async (e) => {
			e.preventDefault();

			const msgs = {
				success: form.dataset.success || '留言已收到，我们会尽快回复您！',
				fail: form.dataset.fail || '发送失败，请稍后重试',
				required: form.dataset.required || '请填写所有必填项',
				sending: form.dataset.sending || '发送中...',
				networkError: form.dataset.networkError || '网络错误，请检查连接后重试',
			};

			let hasError = false;
			form.querySelectorAll('[data-required]').forEach(el => {
				if (!(el as HTMLInputElement).value.trim()) {
					el.classList.add('error');
					hasError = true;
				}
			});

			if (hasError) {
				showToast(msgs.required, 'fail');
				return;
			}

			const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
			const originalText = btn.textContent;
			btn.disabled = true;
			btn.textContent = msgs.sending;

			const formData = new FormData(form);
			const data = Object.fromEntries(formData.entries());

			try {
				const response = await fetch(form.action, {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
						'Accept': 'application/json',
					},
					body: JSON.stringify(data),
				});

				if (response.ok) {
					onSuccess();
				} else {
					const result = await response.json().catch(() => null);
					showToast(result?.error || msgs.fail, 'fail');
				}
			} catch {
				showToast(msgs.networkError, 'fail');
			} finally {
				btn.disabled = false;
				btn.textContent = originalText;
			}

			function onSuccess() {
				form.reset();
				form.querySelectorAll('.error').forEach(el => el.classList.remove('error'));
				showToast(msgs.success, 'success');
			}
		});
	}

	function showToast(msg: string, type: 'success' | 'fail') {
		if (!toast) return;
		toast.textContent = msg;
		toast.className = `form-toast ${type} show`;
		setTimeout(() => toast.classList.remove('show'), 4000);
	}
</script>
