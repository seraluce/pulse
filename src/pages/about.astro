---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import { site } from '../config';

const pageCfg = site.pages.about;
const iconSvg = site.icons.values;
---

<Layout page={{ title: pageCfg.hero.title, path: '/about', description: site.description }}>
	<Header />
	<main>
		<section class="page-hero">
			<div class="container">
				<span class="section-tag animate-on-scroll">{pageCfg.hero.tag}</span>
				<h1 class="animate-on-scroll delay-1">{pageCfg.hero.title}</h1>
				<p class="animate-on-scroll delay-2">{pageCfg.hero.subtitle}</p>
			</div>
		</section>

		<section class="story section">
			<div class="container">
				<div class="story-grid">
					<div class="story-content animate-on-scroll">
						<h2>{pageCfg.story.title}</h2>
						{pageCfg.story.paragraphs.map((p) => (
							<p>{p}</p>
						))}
					</div>
					<div class="story-stats animate-on-scroll delay-2">
						{pageCfg.story.stats.map((stat) => (
							<div class="stat-card">
								<span class="stat-num">{stat.num}</span>
								<span class="stat-label">{stat.label}</span>
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

		<section class="values section">
			<div class="container">
				<div class="section-header animate-on-scroll">
					<span class="section-tag">{pageCfg.values.header.tag}</span>
					<h2>{pageCfg.values.header.title}</h2>
					{pageCfg.values.header.subtitle && <p>{pageCfg.values.header.subtitle}</p>}
				</div>
				<div class="values-grid">
					{pageCfg.values.items.map((v, i) => (
						<div class={`value-card animate-on-scroll delay-${i + 1}`}>
							<div class="value-icon" set:html={`<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">${iconSvg[v.icon]}</svg>`}></div>
							<h3>{v.title}</h3>
							<p>{v.desc}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="timeline-section section">
			<div class="container">
				<div class="section-header animate-on-scroll">
					<span class="section-tag">{pageCfg.timeline.header.tag}</span>
					<h2>{pageCfg.timeline.header.title}</h2>
				</div>
				<div class="timeline">
					<div class="timeline-center-line"></div>
					{pageCfg.timeline.items.map((m, i) => (
						<div class={`timeline-row ${i % 2 === 0 ? 'left' : 'right'} animate-on-scroll delay-${(i % 3) + 1}`}>
							<div class="timeline-card">
								<span class="timeline-year">{m.year}</span>
								<h3>{m.title}</h3>
								<p>{m.desc}</p>
							</div>
							<div class="timeline-node"></div>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="team section">
			<div class="container">
				<div class="section-header animate-on-scroll">
					<span class="section-tag">{pageCfg.team.header.tag}</span>
					<h2>{pageCfg.team.header.title}</h2>
				</div>
				<div class="team-grid">
					{pageCfg.team.members.map((t, i) => (
						<div class={`team-card animate-on-scroll delay-${i + 1}`}>
							<div class="team-avatar">{t.name[0]}</div>
							<h3>{t.name}</h3>
							<span class="team-role">{t.role}</span>
							<p>{t.desc}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<CTA />
	</main>
	<Footer />
</Layout>

<style>
	.page-hero {
		padding-top: calc(var(--header-height) + 80px);
		padding-bottom: 80px;
		text-align: center;
	}

	.section-tag {
		display: inline-block;
		font-size: 12px;
		letter-spacing: 0.15em;
		color: var(--color-text-tertiary);
		margin-bottom: 16px;
		text-transform: uppercase;
	}

	.page-hero h1 {
		font-size: clamp(32px, 4.5vw, 48px);
		font-weight: 700;
		letter-spacing: -0.03em;
		margin-bottom: 16px;
	}

	.page-hero p {
		font-size: 17px;
		color: var(--color-text-secondary);
		max-width: 560px;
		margin: 0 auto;
		line-height: 1.7;
	}

	.section-header {
		text-align: center;
		margin-bottom: 56px;
	}

	.section-header h2 {
		font-size: clamp(28px, 3.5vw, 40px);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin-bottom: 12px;
	}

	.section-header p {
		font-size: 16px;
		color: var(--color-text-secondary);
	}

	/* Story */
	.story { background: var(--color-bg); }

	.story-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 80px;
		align-items: center;
	}

	.story-content h2 {
		font-size: clamp(24px, 3vw, 36px);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin-bottom: 24px;
	}

	.story-content p {
		font-size: 15px;
		line-height: 1.8;
		color: var(--color-text-secondary);
		margin-bottom: 16px;
	}

	.story-stats {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 16px;
	}

	.stat-card {
		padding: 28px 24px;
		background: var(--color-card-bg-gradient);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		text-align: center;
		transition: border-color var(--transition-fast), box-shadow var(--transition-fast), transform var(--transition-fast);
	}

	.stat-card:hover {
		border-color: var(--color-text);
		box-shadow: 0 6px 24px var(--color-card-shadow-hover);
		transform: translateY(-2px);
	}

	.stat-num {
		display: block;
		font-size: 32px;
		font-weight: 700;
		letter-spacing: -0.02em;
		margin-bottom: 4px;
	}

	.stat-label {
		font-size: 13px;
		color: var(--color-text-tertiary);
	}

	/* Values */
	.values { background: var(--color-bg-secondary); }

	.values-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1px;
		background: var(--color-border);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		overflow: hidden;
	}

	.value-card {
		padding: 36px 24px;
		background: var(--color-card-bg-gradient);
		text-align: center;
		transition: background var(--transition-fast), box-shadow var(--transition-fast), transform var(--transition-fast);
		position: relative;
		overflow: hidden;
	}

	.value-card::before {
		content: "";
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		height: 2px;
		background: linear-gradient(90deg, transparent, var(--color-highlight), transparent);
		opacity: 0;
		transition: opacity var(--transition-fast);
	}

	.value-card:hover {
		background: var(--color-card-bg-hover);
		box-shadow: 0 8px 32px var(--color-card-shadow-hover);
		transform: translateY(-2px);
	}

	.value-card:hover::before {
		opacity: 1;
	}

	.value-icon {
		width: 48px;
		height: 48px;
		display: flex;
		align-items: center;
		justify-content: center;
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		margin: 0 auto 16px;
		color: var(--color-text);
		background: var(--color-bg-tertiary);
		transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
	}

	.value-card:hover .value-icon {
		border-color: var(--color-highlight);
		box-shadow: 0 4px 16px var(--color-card-glow);
	}

	.value-card h3 {
		font-size: 16px;
		font-weight: 600;
		margin-bottom: 8px;
	}

	.value-card p {
		font-size: 14px;
		color: var(--color-text-secondary);
		line-height: 1.6;
	}

	/* Timeline */
	.timeline-section { background: var(--color-bg); }

	.timeline {
		position: relative;
		max-width: 800px;
		margin: 0 auto;
	}

	.timeline-center-line {
		position: absolute;
		left: 50%;
		top: 0;
		bottom: 0;
		width: 1px;
		background: var(--color-border);
		transform: translateX(-50%);
	}

	.timeline-row {
		position: relative;
		display: flex;
		margin-bottom: 32px;
	}

	.timeline-row.left {
		justify-content: flex-start;
		padding-right: calc(50% + 32px);
		text-align: right;
	}

	.timeline-row.right {
		justify-content: flex-end;
		padding-left: calc(50% + 32px);
	}

	.timeline-node {
		position: absolute;
		left: 50%;
		top: 20px;
		width: 12px;
		height: 12px;
		border-radius: 50%;
		background: var(--color-text);
		border: 3px solid var(--color-bg);
		transform: translateX(-50%);
		z-index: 1;
	}

	.timeline-card {
		padding: 24px;
		background: var(--color-card-bg-gradient);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		transition: border-color var(--transition-fast), box-shadow var(--transition-fast), transform var(--transition-fast);
	}

	.timeline-card:hover {
		border-color: var(--color-text);
		box-shadow: 0 6px 24px var(--color-card-shadow-hover);
		transform: translateY(-2px);
	}

	.timeline-year {
		font-size: 12px;
		font-weight: 600;
		color: var(--color-text-tertiary);
		letter-spacing: 0.08em;
		margin-bottom: 6px;
		display: block;
	}

	.timeline-card h3 {
		font-size: 16px;
		font-weight: 600;
		margin-bottom: 6px;
	}

	.timeline-card p {
		font-size: 14px;
		color: var(--color-text-secondary);
		line-height: 1.6;
	}

	/* Team */
	.team { background: var(--color-bg-secondary); }

	.team-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 24px;
	}

	.team-card {
		text-align: center;
		padding: 36px 20px;
		background: var(--color-card-bg-gradient);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		transition: border-color var(--transition-fast), box-shadow var(--transition-fast), transform var(--transition-fast);
	}

	.team-card:hover {
		border-color: var(--color-text);
		box-shadow: 0 8px 32px var(--color-card-shadow-hover);
		transform: translateY(-3px);
	}

	.team-avatar {
		width: 64px;
		height: 64px;
		border-radius: 50%;
		background: var(--color-accent);
		color: var(--color-bg);
		display: flex;
		align-items: center;
		justify-content: center;
		margin: 0 auto 16px;
		font-size: 22px;
		font-weight: 700;
	}

	.team-card h3 {
		font-size: 16px;
		font-weight: 600;
		margin-bottom: 4px;
	}

	.team-role {
		font-size: 13px;
		color: var(--color-text-tertiary);
		display: block;
		margin-bottom: 8px;
	}

	.team-card p {
		font-size: 13px;
		color: var(--color-text-tertiary);
	}

	@media (max-width: 900px) {
		.story-grid { grid-template-columns: 1fr; gap: 40px; }
		.values-grid { grid-template-columns: repeat(2, 1fr); }
		.team-grid { grid-template-columns: repeat(2, 1fr); }
		.timeline-center-line { left: 20px; }
		.timeline-row.left,
		.timeline-row.right {
			justify-content: flex-start;
			padding-left: 52px;
			padding-right: 0;
			text-align: left;
		}
		.timeline-node { left: 20px; }
	}

	@media (max-width: 480px) {
		.values-grid { grid-template-columns: 1fr; }
		.team-grid { grid-template-columns: 1fr; }
	}
</style>
