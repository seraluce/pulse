---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Features from '../components/Features.astro';
import About from '../components/About.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout page={{ title: '服务', path: '/services', description: '战略咨询、数字化转型、品牌建设、数据驱动、增长运营、技术支持 — 覆盖企业发展全链路的专业服务。' }}>
	<Header />
	<main>
		<section class="page-hero">
			<div class="container">
				<span class="section-tag animate-on-scroll">OUR SERVICES</span>
				<h1 class="animate-on-scroll delay-1">服务与能力</h1>
				<p class="animate-on-scroll delay-2">覆盖企业发展全链路的专业服务体系，从战略规划到落地执行</p>
			</div>
		</section>
		<Features />
		<About />
		<CTA />
	</main>
	<Footer />
</Layout>

<style>
	.page-hero {
		padding-top: calc(var(--header-height) + 80px);
		padding-bottom: 80px;
		text-align: center;
		background: var(--color-bg);
	}

	.section-tag {
		display: inline-block;
		font-size: 12px;
		letter-spacing: 0.15em;
		color: var(--color-text-tertiary);
		margin-bottom: 16px;
		text-transform: uppercase;
	}

	.page-hero h1 {
		font-size: clamp(32px, 4.5vw, 48px);
		font-weight: 700;
		letter-spacing: -0.03em;
		margin-bottom: 16px;
	}

	.page-hero p {
		font-size: 17px;
		color: var(--color-text-secondary);
		max-width: 520px;
		margin: 0 auto;
		line-height: 1.7;
	}
</style>
