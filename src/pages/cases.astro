---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import { site } from '../config';

const pageCfg = site.pages.cases;
---

<Layout page={{ title: pageCfg.hero.title, path: '/cases', description: site.description }}>
	<Header />
	<main>
		<section class="page-hero">
			<div class="container">
				<span class="section-tag animate-on-scroll">{pageCfg.hero.tag}</span>
				<h1 class="animate-on-scroll delay-1">{pageCfg.hero.title}</h1>
				<p class="animate-on-scroll delay-2">{pageCfg.hero.subtitle}</p>
			</div>
		</section>

		<section class="cases section">
			<div class="container">
				<div class="cases-grid">
					{pageCfg.cases.map((c, i) => (
						<div class={`case-card animate-on-scroll delay-${(i % 3) + 1}`}>
							<div class="case-header">
								<span class="case-category">{c.category}</span>
								<span class="case-result">{c.result}</span>
							</div>
							<h3>{c.title}</h3>
							<p>{c.desc}</p>
							<div class="case-tags">
								{c.tags.map(tag => <span class="case-tag">{tag}</span>)}
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="process section">
			<div class="container">
				<div class="section-header animate-on-scroll">
					<span class="section-tag">{pageCfg.process.header.tag}</span>
					<h2>{pageCfg.process.header.title}</h2>
					{pageCfg.process.header.subtitle && <p>{pageCfg.process.header.subtitle}</p>}
				</div>
				<div class="process-steps">
					{pageCfg.process.steps.map((step, i) => (
						<div class={`process-step animate-on-scroll delay-${i + 1}`}>
							<span class="step-num">{step.num}</span>
							<h3>{step.title}</h3>
							<p>{step.desc}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<CTA />
	</main>
	<Footer />
</Layout>

<style>
	.page-hero {
		padding-top: calc(var(--header-height) + 80px);
		padding-bottom: 80px;
		text-align: center;
	}

	.section-tag {
		display: inline-block;
		font-size: 12px;
		letter-spacing: 0.15em;
		color: var(--color-text-tertiary);
		margin-bottom: 16px;
		text-transform: uppercase;
	}

	.page-hero h1 {
		font-size: clamp(32px, 4.5vw, 48px);
		font-weight: 700;
		letter-spacing: -0.03em;
		margin-bottom: 16px;
	}

	.page-hero p {
		font-size: 17px;
		color: var(--color-text-secondary);
		max-width: 520px;
		margin: 0 auto;
		line-height: 1.7;
	}

	.cases { background: var(--color-bg); }

	.cases-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 28px;
	}

	.case-card {
		padding: 40px 32px;
		background: var(--color-card-bg-gradient);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		transition: border-color var(--transition-fast), box-shadow var(--transition-fast), transform var(--transition-fast);
		position: relative;
		overflow: hidden;
	}

	.case-card::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: radial-gradient(ellipse at 100% 0%, var(--card-accent, var(--color-card-glow)) 0%, transparent 50%);
		opacity: 0;
		transition: opacity var(--transition-slow);
		pointer-events: none;
	}

	.case-card::after {
		content: "";
		position: absolute;
		left: 0;
		top: 0;
		bottom: 0;
		width: 3px;
		background: var(--card-accent-line, var(--color-highlight));
		opacity: 0;
		transition: opacity var(--transition-fast);
	}

	.case-card:nth-child(1) { --card-accent: rgba(59, 130, 246, 0.1); --card-accent-line: #3b82f6; }
	.case-card:nth-child(2) { --card-accent: rgba(139, 92, 246, 0.1); --card-accent-line: #8b5cf6; }
	.case-card:nth-child(3) { --card-accent: rgba(6, 182, 212, 0.1); --card-accent-line: #06b6d4; }
	.case-card:nth-child(4) { --card-accent: rgba(245, 158, 11, 0.1); --card-accent-line: #f59e0b; }
	.case-card:nth-child(5) { --card-accent: rgba(16, 185, 129, 0.1); --card-accent-line: #10b981; }
	.case-card:nth-child(6) { --card-accent: rgba(236, 72, 153, 0.1); --card-accent-line: #ec4899; }

	.case-card:hover {
		border-color: var(--card-accent-line, var(--color-text));
		box-shadow: 0 12px 40px var(--color-card-shadow-hover);
		transform: translateY(-4px);
	}

	.case-card:hover::before {
		opacity: 1;
	}

	.case-card:hover::after {
		opacity: 1;
	}

	.case-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 18px;
		position: relative;
		z-index: 1;
	}

	.case-category {
		font-size: 12px;
		font-weight: 500;
		color: var(--color-text-secondary);
		padding: 4px 12px;
		border: 1px solid var(--color-border);
		border-radius: 100px;
		background: var(--color-card-bg);
	}

	.case-result {
		font-size: 13px;
		font-weight: 600;
		color: var(--card-accent-line, var(--color-highlight));
	}

	.case-card h3 {
		font-size: 18px;
		font-weight: 600;
		margin-bottom: 10px;
		letter-spacing: -0.01em;
		position: relative;
		z-index: 1;
	}

	.case-card p {
		font-size: 14px;
		line-height: 1.7;
		color: var(--color-text-secondary);
		margin-bottom: 18px;
		position: relative;
		z-index: 1;
	}

	.case-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
	}

	.case-tag {
		font-size: 11px;
		padding: 3px 8px;
		background: var(--color-bg-tertiary);
		color: var(--color-text-tertiary);
		border-radius: 4px;
	}

	.process { background: var(--color-bg-secondary); }

	.section-header {
		text-align: center;
		margin-bottom: 56px;
	}

	.section-header h2 {
		font-size: clamp(28px, 3.5vw, 40px);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin-bottom: 12px;
	}

	.section-header p {
		font-size: 16px;
		color: var(--color-text-secondary);
	}

	.process-steps {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 24px;
	}

	.process-step {
		text-align: center;
		padding: 32px 20px;
	}

	.step-num {
		display: block;
		font-size: 40px;
		font-weight: 800;
		color: var(--color-text-tertiary);
		margin-bottom: 16px;
		opacity: 0.4;
	}

	.process-step h3 {
		font-size: 17px;
		font-weight: 600;
		margin-bottom: 8px;
	}

	.process-step p {
		font-size: 14px;
		color: var(--color-text-secondary);
		line-height: 1.6;
	}

	@media (max-width: 900px) {
		.cases-grid { grid-template-columns: repeat(2, 1fr); }
		.process-steps { grid-template-columns: repeat(2, 1fr); }
	}

	@media (max-width: 560px) {
		.cases-grid { grid-template-columns: 1fr; }
		.process-steps { grid-template-columns: 1fr; }
	}
</style>
