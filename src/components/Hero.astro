---

<section class="hero">
	<div class="container hero-inner">
		<div class="hero-content">
			<div class="hero-badge">专业 · 高效 · 可靠</div>
			<h1>
				用专业方案<br/>
				<span>驱动业务增长</span>
			</h1>
			<p class="hero-desc">
				我们为企业提供全方位的数字化解决方案，从战略规划到落地执行，帮助您在竞争中脱颖而出。
			</p>
			<div class="hero-actions">
				<a href="/contact" class="btn btn-primary">立即咨询</a>
				<a href="/services" class="btn btn-outline">了解更多</a>
			</div>
			<div class="hero-stats">
				<div class="stat">
					<span class="stat-num">500+</span>
					<span class="stat-label">服务客户</span>
				</div>
				<div class="stat-divider"></div>
				<div class="stat">
					<span class="stat-num">98%</span>
					<span class="stat-label">客户满意度</span>
				</div>
				<div class="stat-divider"></div>
				<div class="stat">
					<span class="stat-num">10+</span>
					<span class="stat-label">年行业经验</span>
				</div>
			</div>
		</div>
		<div class="hero-visual">
			<div class="hero-ripple-bg">
				<div class="ripple ripple-1"></div>
				<div class="ripple ripple-2"></div>
				<div class="ripple ripple-3"></div>
				<div class="ripple ripple-4"></div>
				<div class="ripple ripple-5"></div>
				<div class="ripple ripple-6"></div>
				<div class="ripple-core"></div>
			</div>
		</div>
	</div>
</section>

<style>
	.hero {
		min-height: 100dvh;
		display: flex;
		align-items: center;
		padding-top: var(--header-height);
	}

	.hero-inner {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 60px;
		align-items: center;
	}

	.hero-badge {
		display: inline-block;
		padding: 6px 16px;
		font-size: 12px;
		letter-spacing: 0.1em;
		color: var(--color-text-secondary);
		border: 1px solid var(--color-border);
		border-radius: 100px;
		margin-bottom: 24px;
	}

	.hero h1 {
		font-size: clamp(36px, 5vw, 56px);
		font-weight: 700;
		line-height: 1.15;
		letter-spacing: -0.03em;
		margin-bottom: 24px;
	}

	.hero h1 span {
		color: var(--color-text-tertiary);
	}

	.hero-desc {
		font-size: 17px;
		line-height: 1.7;
		color: var(--color-text-secondary);
		max-width: 480px;
		margin-bottom: 36px;
	}

	.hero-actions {
		display: flex;
		gap: 12px;
		margin-bottom: 48px;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 12px 28px;
		font-size: 15px;
		font-weight: 500;
		border-radius: var(--radius);
		transition: all var(--transition-fast);
	}

	.btn-primary {
		background: var(--color-accent);
		color: var(--color-bg);
		border: 1px solid var(--color-accent);
	}

	.btn-primary:hover {
		background: var(--color-accent-hover);
		border-color: var(--color-accent-hover);
	}

	.btn-outline {
		background: transparent;
		color: var(--color-text);
		border: 1px solid var(--color-border);
	}

	.btn-outline:hover {
		border-color: var(--color-text);
	}

	.hero-stats {
		display: flex;
		align-items: center;
		gap: 24px;
	}

	.stat {
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.stat-num {
		font-size: 24px;
		font-weight: 700;
		letter-spacing: -0.02em;
	}

	.stat-label {
		font-size: 13px;
		color: var(--color-text-tertiary);
	}

	.stat-divider {
		width: 1px;
		height: 36px;
		background: var(--color-border);
	}

	/* 涟漪 — 桌面端右侧背景 */
	.hero-visual {
		display: flex;
		justify-content: center;
		align-items: center;
	}

	.hero-ripple-bg {
		position: relative;
		width: 700px;
		height: 700px;
	}

	.ripple {
		position: absolute;
		top: 50%;
		left: 50%;
		width: 40px;
		height: 40px;
		border-radius: 50%;
		border: 5px solid var(--color-text);
		opacity: 0;
		transform: translate(-50%, -50%);
		animation: ripple-expand 8s cubic-bezier(0, 0.2, 0.8, 1) infinite;
	}

	.ripple-1 { animation-delay: 0s; }
	.ripple-2 { animation-delay: 1.33s; }
	.ripple-3 { animation-delay: 2.66s; }
	.ripple-4 { animation-delay: 4s; }
	.ripple-5 { animation-delay: 5.33s; }
	.ripple-6 { animation-delay: 6.66s; }

	@keyframes ripple-expand {
		0% {
			width: 40px;
			height: 40px;
			opacity: 0.25;
			border-width: 5px;
		}
		50% {
			opacity: 0.15;
			border-width: 3px;
		}
		100% {
			width: 700px;
			height: 700px;
			opacity: 0;
			border-width: 1px;
		}
	}

	.ripple-core {
		position: absolute;
		top: 50%;
		left: 50%;
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--color-text);
		transform: translate(-50%, -50%);
		animation: core-pulse 2s ease-in-out infinite;
	}

	@keyframes core-pulse {
		0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.6; }
		50% { transform: translate(-50%, -50%) scale(1.8); opacity: 0.2; }
	}

	/* 移动端：涟漪作为全屏背景 */
	@media (max-width: 900px) {
		.hero-inner {
			grid-template-columns: 1fr;
			text-align: center;
		}
		.hero-desc { margin-left: auto; margin-right: auto; margin-bottom: 28px; }
		.hero-actions { justify-content: center; margin-bottom: 36px; }
		.hero-stats { justify-content: center; }

		.hero {
			position: relative;
			overflow: hidden;
		}

		.hero-visual {
			position: absolute;
			top: 50%;
			left: 50%;
			transform: translate(-50%, -50%);
			pointer-events: none;
			z-index: 0;
		}

		.hero-ripple-bg {
			width: 900px;
			height: 900px;
		}

		.hero-inner {
			position: relative;
			z-index: 1;
		}

		@keyframes ripple-expand {
			0% {
				width: 30px;
				height: 30px;
				opacity: 0.2;
				border-width: 4px;
			}
			50% {
				opacity: 0.12;
				border-width: 3px;
			}
			100% {
				width: 900px;
				height: 900px;
				opacity: 0;
				border-width: 1px;
			}
		}
	}

	@media (max-width: 480px) {
		.hero-actions { flex-direction: column; }
		.hero-stats { flex-wrap: wrap; gap: 16px; }
		.hero h1 { font-size: clamp(28px, 8vw, 40px); }
		.hero-desc { font-size: 15px; }

		.hero-ripple-bg {
			width: 700px;
			height: 700px;
		}

		@keyframes ripple-expand {
			0% {
				width: 24px;
				height: 24px;
				opacity: 0.18;
				border-width: 4px;
			}
			50% {
				opacity: 0.1;
				border-width: 2.5px;
			}
			100% {
				width: 700px;
				height: 700px;
				opacity: 0;
				border-width: 1px;
			}
		}
	}
</style>
