---

<section class="hero">
	<div class="hero-ripple-bg">
		<div class="ripple ripple-1"></div>
		<div class="ripple ripple-2"></div>
		<div class="ripple ripple-3"></div>
		<div class="ripple ripple-4"></div>
		<div class="ripple-core"></div>
	</div>
	<div class="container hero-inner">
		<div class="hero-content">
			<div class="hero-badge">专业 · 高效 · 可靠</div>
			<h1>
				用专业方案<br/>
				<span>驱动业务增长</span>
			</h1>
			<p class="hero-desc">
				我们为企业提供全方位的数字化解决方案，从战略规划到落地执行，帮助您在竞争中脱颖而出。
			</p>
			<div class="hero-actions">
				<a href="/contact" class="btn btn-primary">立即咨询</a>
				<a href="/services" class="btn btn-outline">了解更多</a>
			</div>
			<div class="hero-stats">
				<div class="stat">
					<span class="stat-num">500+</span>
					<span class="stat-label">服务客户</span>
				</div>
				<div class="stat-divider"></div>
				<div class="stat">
					<span class="stat-num">98%</span>
					<span class="stat-label">客户满意度</span>
				</div>
				<div class="stat-divider"></div>
				<div class="stat">
					<span class="stat-num">10+</span>
					<span class="stat-label">年行业经验</span>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.hero {
		min-height: 100dvh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding-top: var(--header-height);
		position: relative;
		overflow: hidden;
		text-align: center;
	}

	/* 涟漪背景层 */
	.hero-ripple-bg {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 900px;
		height: 900px;
		pointer-events: none;
		z-index: 0;
	}

	.ripple {
		position: absolute;
		top: 50%;
		left: 50%;
		width: 40px;
		height: 40px;
		border-radius: 50%;
		border: 3px solid var(--color-border);
		transform: translate(-50%, -50%);
		opacity: 0;
		animation: ripple-expand 6s cubic-bezier(0, 0.2, 0.8, 1) infinite;
	}

	.ripple-1 { animation-delay: 0s; }
	.ripple-2 { animation-delay: 1.5s; }
	.ripple-3 { animation-delay: 3s; }
	.ripple-4 { animation-delay: 4.5s; }

	@keyframes ripple-expand {
		0% {
			width: 40px;
			height: 40px;
			opacity: 0.8;
			border-width: 3px;
		}
		100% {
			width: 900px;
			height: 900px;
			opacity: 0;
			border-width: 1px;
		}
	}

	.ripple-core {
		position: absolute;
		top: 50%;
		left: 50%;
		width: 16px;
		height: 16px;
		border-radius: 50%;
		background: var(--color-text);
		transform: translate(-50%, -50%);
		animation: core-pulse 2s ease-in-out infinite;
		opacity: 0.4;
	}

	@keyframes core-pulse {
		0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.4; }
		50% { transform: translate(-50%, -50%) scale(1.6); opacity: 0.15; }
	}

	.hero-inner {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.hero-content {
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.hero-badge {
		display: inline-block;
		padding: 6px 16px;
		font-size: 12px;
		letter-spacing: 0.1em;
		color: var(--color-text-secondary);
		border: 1px solid var(--color-border);
		border-radius: 100px;
		margin-bottom: 24px;
	}

	.hero h1 {
		font-size: clamp(36px, 5.5vw, 64px);
		font-weight: 700;
		line-height: 1.15;
		letter-spacing: -0.03em;
		margin-bottom: 24px;
	}

	.hero h1 span {
		color: var(--color-text-tertiary);
	}

	.hero-desc {
		font-size: 17px;
		line-height: 1.7;
		color: var(--color-text-secondary);
		max-width: 520px;
		margin-bottom: 36px;
	}

	.hero-actions {
		display: flex;
		gap: 12px;
		margin-bottom: 48px;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 12px 28px;
		font-size: 15px;
		font-weight: 500;
		border-radius: var(--radius);
		transition: all var(--transition-fast);
	}

	.btn-primary {
		background: var(--color-accent);
		color: var(--color-bg);
		border: 1px solid var(--color-accent);
	}

	.btn-primary:hover {
		background: var(--color-accent-hover);
		border-color: var(--color-accent-hover);
	}

	.btn-outline {
		background: transparent;
		color: var(--color-text);
		border: 1px solid var(--color-border);
	}

	.btn-outline:hover {
		border-color: var(--color-text);
	}

	.hero-stats {
		display: flex;
		align-items: center;
		gap: 24px;
	}

	.stat {
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.stat-num {
		font-size: 24px;
		font-weight: 700;
		letter-spacing: -0.02em;
	}

	.stat-label {
		font-size: 13px;
		color: var(--color-text-tertiary);
	}

	.stat-divider {
		width: 1px;
		height: 36px;
		background: var(--color-border);
	}

	@media (max-width: 768px) {
		.hero-ripple-bg {
			width: 600px;
			height: 600px;
		}

		@keyframes ripple-expand {
			0% {
				width: 30px;
				height: 30px;
				opacity: 0.7;
				border-width: 2.5px;
			}
			100% {
				width: 600px;
				height: 600px;
				opacity: 0;
				border-width: 0.5px;
			}
		}

		.hero-actions { flex-direction: column; width: 100%; max-width: 300px; }
		.btn { width: 100%; }
	}

	@media (max-width: 480px) {
		.hero-ripple-bg {
			width: 450px;
			height: 450px;
		}

		@keyframes ripple-expand {
			0% {
				width: 24px;
				height: 24px;
				opacity: 0.6;
				border-width: 2px;
			}
			100% {
				width: 450px;
				height: 450px;
				opacity: 0;
				border-width: 0.5px;
			}
		}

		.hero-stats { flex-wrap: wrap; gap: 16px; justify-content: center; }
		.hero h1 { font-size: clamp(28px, 8vw, 40px); }
		.hero-desc { font-size: 15px; }
	}
</style>
