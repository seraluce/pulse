---
import { site } from '../config';
const hero = site.hero;
---

<section class="hero" id="hero">
	<div class="hero-orbs" id="heroOrbs">
		<div class="orb orb-1"></div>
		<div class="orb orb-2"></div>
		<div class="orb orb-3"></div>
	</div>
	<div class="hero-sphere-wrap">
		<div class="hero-sphere" id="heroSphere"></div>
	</div>
	<div class="container hero-inner">
		<div class="hero-content">
			<div class="hero-badge" data-i18n="hero.badge">{hero.badge}</div>
			<h1>
				<span data-i18n="hero.titleMain">{hero.titleMain}</span><br/>
				<span data-i18n="hero.titleHighlight">{hero.titleHighlight}</span>
			</h1>
			<p class="hero-desc" data-i18n="hero.description">{hero.description}</p>
			<div class="hero-actions">
				<a href={hero.primaryButton.href} class="btn btn-primary" data-i18n="hero.primaryButton">{hero.primaryButton.label}</a>
				<a href={hero.secondaryButton.href} class="btn btn-outline" data-i18n="hero.secondaryButton">{hero.secondaryButton.label}</a>
			</div>
			<div class="hero-stats" data-i18n-repeat="hero.stats">
				<div class="stat" data-i18n-template style="display:none">
					<span class="stat-num" data-i18n-field="num"></span>
					<span class="stat-label" data-i18n-field="label"></span>
				</div>
				{hero.stats.map((stat, i) => (
					<>
						{i > 0 && <div class="stat-divider"></div>}
						<div class="stat" data-i18n-item>
							<span class="stat-num" data-i18n-field="num">{stat.num}</span>
							<span class="stat-label" data-i18n-field="label">{stat.label}</span>
						</div>
					</>
				))}
			</div>
		</div>
	</div>
</section>

<style>
	.hero {
		min-height: 100dvh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding-top: var(--header-height);
		position: relative;
		overflow: hidden;
		text-align: center;
	}

	/* 背景光晕 - 彩色 */
	.hero-orbs {
		position: absolute;
		inset: 0;
		z-index: 0;
		pointer-events: none;
	}

	.orb {
		position: absolute;
		border-radius: 50%;
		filter: blur(80px);
		will-change: transform;
		transition: transform 0.3s ease-out;
	}

	.orb-1 {
		width: 500px;
		height: 500px;
		top: 5%;
		left: 10%;
		background: radial-gradient(circle, rgba(0, 220, 130, 0.5) 0%, rgba(0, 220, 130, 0.2) 40%, transparent 70%);
		animation: float-a 14s ease-in-out infinite;
	}

	.orb-2 {
		width: 420px;
		height: 420px;
		top: 40%;
		right: 10%;
		background: radial-gradient(circle, rgba(59, 130, 246, 0.45) 0%, rgba(59, 130, 246, 0.15) 40%, transparent 70%);
		animation: float-b 18s ease-in-out infinite;
	}

	.orb-3 {
		width: 360px;
		height: 360px;
		bottom: 10%;
		left: 30%;
		background: radial-gradient(circle, rgba(255, 200, 50, 0.4) 0%, rgba(255, 200, 50, 0.15) 40%, transparent 70%);
		animation: float-c 12s ease-in-out infinite;
	}

	:root.dark .orb-1 {
		background: radial-gradient(circle, rgba(0, 220, 130, 0.3) 0%, rgba(0, 220, 130, 0.08) 40%, transparent 70%);
	}
	:root.dark .orb-2 {
		background: radial-gradient(circle, rgba(255, 138, 76, 0.25) 0%, rgba(255, 138, 76, 0.06) 40%, transparent 70%);
	}
	:root.dark .orb-3 {
		background: radial-gradient(circle, rgba(255, 217, 61, 0.2) 0%, rgba(255, 217, 61, 0.05) 40%, transparent 70%);
	}

	@keyframes float-a {
		0%, 100% { transform: translate(0, 0) scale(1); }
		25% { transform: translate(40px, -30px) scale(1.08); }
		50% { transform: translate(-20px, 35px) scale(0.95); }
		75% { transform: translate(30px, 20px) scale(1.05); }
	}

	@keyframes float-b {
		0%, 100% { transform: translate(0, 0) scale(1); }
		33% { transform: translate(-35px, 25px) scale(1.1); }
		66% { transform: translate(25px, -20px) scale(0.94); }
	}

	@keyframes float-c {
		0%, 100% { transform: translate(0, 0) scale(1); }
		50% { transform: translate(-25px, 35px) scale(1.12); }
	}

	/* 中央呼吸球 - 彩色 */
	.hero-sphere-wrap {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		z-index: 0;
		pointer-events: none;
	}

	.hero-sphere {
		width: 220px;
		height: 220px;
		border-radius: 50%;
		background: radial-gradient(circle at 35% 35%,
			rgba(0, 220, 130, 0.5) 0%,
			rgba(59, 130, 246, 0.35) 35%,
			rgba(255, 200, 50, 0.2) 65%,
			transparent 80%
		);
		box-shadow:
			0 0 80px rgba(0, 220, 130, 0.35),
			0 0 160px rgba(59, 130, 246, 0.2),
			inset 0 0 60px rgba(0, 220, 130, 0.25);
		animation: sphere-breathe 4s ease-in-out infinite;
	}

	:root.dark .hero-sphere {
		background: radial-gradient(circle at 35% 35%,
			rgba(0, 220, 130, 0.3) 0%,
			rgba(255, 138, 76, 0.18) 35%,
			rgba(255, 217, 61, 0.1) 65%,
			transparent 80%
		);
		box-shadow:
			0 0 80px rgba(0, 220, 130, 0.18),
			0 0 160px rgba(255, 138, 76, 0.1),
			inset 0 0 60px rgba(0, 220, 130, 0.12);
	}

	@keyframes sphere-breathe {
		0%, 100% { transform: scale(1); opacity: 0.8; }
		50% { transform: scale(1.2); opacity: 1; }
	}

	/* 网格背景 */
	.hero::after {
		content: "";
		position: absolute;
		inset: 0;
		background-image: 
			linear-gradient(rgba(128, 128, 128, 0.03) 1px, transparent 1px),
			linear-gradient(90deg, rgba(128, 128, 128, 0.03) 1px, transparent 1px);
		background-size: 48px 48px;
		mask-image: radial-gradient(ellipse at center, black 0%, transparent 70%);
		-webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 70%);
		pointer-events: none;
		z-index: 0;
	}

	/* 内容 */
	.hero-inner {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.hero-content {
		display: flex;
		flex-direction: column;
		align-items: center;
		max-width: 800px;
	}

	.hero-badge {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 8px 20px;
		font-size: 13px;
		font-weight: 500;
		letter-spacing: 0.02em;
		color: #00DC82;
		border: 1px solid rgba(0, 220, 130, 0.3);
		border-radius: 100px;
		margin-bottom: 28px;
		background: rgba(0, 220, 130, 0.1);
		backdrop-filter: blur(8px);
	}

	:root.dark .hero-badge {
		color: #00DC82;
		border: 1px solid rgba(0, 220, 130, 0.25);
		background: rgba(0, 220, 130, 0.06);
	}

	.hero-badge::before {
		content: "";
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: #00DC82;
		box-shadow: 0 0 8px rgba(0, 220, 130, 0.6);
		animation: badge-pulse 2s ease-in-out infinite;
	}

	@keyframes badge-pulse {
		0%, 100% { opacity: 1; transform: scale(1); }
		50% { opacity: 0.5; transform: scale(0.85); }
	}

	.hero h1 {
		font-size: clamp(40px, 6vw, 72px);
		font-weight: 700;
		line-height: 1.1;
		letter-spacing: -0.04em;
		margin-bottom: 28px;
	}

	.hero h1 span {
		background: linear-gradient(330deg, #00DC82 0%, #3B82F6 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	:root.dark .hero h1 span {
		background: linear-gradient(330deg, #00DC82 0%, #1664FF 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.hero-desc {
		font-size: 18px;
		line-height: 1.7;
		color: var(--color-text-secondary);
		max-width: 600px;
		margin-bottom: 44px;
	}

	.hero-actions {
		display: flex;
		gap: 16px;
		margin-bottom: 56px;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 14px 32px;
		font-size: 15px;
		font-weight: 500;
		border-radius: var(--radius-lg);
		transition: all var(--transition-fast);
		cursor: pointer;
		text-decoration: none;
	}

	.btn-primary {
		background: linear-gradient(135deg, #00DC82 0%, #3B82F6 100%);
		color: white;
		border: none;
		box-shadow: 0 4px 20px rgba(0, 220, 130, 0.35);
		position: relative;
		overflow: hidden;
	}

	:root.dark .btn-primary {
		background: linear-gradient(135deg, #00DC82 0%, #1664FF 100%);
		box-shadow: 0 4px 20px rgba(0, 220, 130, 0.3);
	}

	.btn-primary::before {
		content: "";
		position: absolute;
		top: 0;
		left: -100%;
		width: 100%;
		height: 100%;
		background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
		transition: left 0.5s ease;
	}

	.btn-primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 8px 32px rgba(0, 220, 130, 0.45);
	}

	:root.dark .btn-primary:hover {
		box-shadow: 0 8px 32px rgba(0, 220, 130, 0.4);
	}

	.btn-primary:hover::before {
		left: 100%;
	}

	.btn-outline {
		background: var(--color-card-bg);
		color: var(--color-text);
		border: 1px solid var(--color-border);
		backdrop-filter: blur(8px);
	}

	.btn-outline:hover {
		border-color: #00DC82;
		color: #00DC82;
		transform: translateY(-2px);
		box-shadow: 0 4px 20px rgba(0, 220, 130, 0.15);
	}

	:root.dark .btn-outline:hover {
		border-color: #00DC82;
		color: #00DC82;
		box-shadow: 0 4px 20px rgba(0, 220, 130, 0.1);
	}

	.hero-stats {
		display: flex;
		align-items: center;
		gap: 0;
		padding: 24px 40px;
		background: var(--color-card-bg-gradient);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		backdrop-filter: blur(8px);
		box-shadow: 0 8px 32px var(--color-card-shadow);
	}

	.stat {
		display: flex;
		flex-direction: column;
		gap: 6px;
		padding: 0 32px;
		text-align: center;
	}

	.stat-num {
		font-size: 28px;
		font-weight: 700;
		letter-spacing: -0.02em;
		background: linear-gradient(135deg, #00DC82, #3B82F6);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	:root.dark .stat-num {
		background: linear-gradient(135deg, #00DC82, #1664FF);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.stat-label {
		font-size: 13px;
		color: var(--color-text-secondary);
		font-weight: 500;
	}

	.stat-divider {
		width: 1px;
		height: 40px;
		background: var(--color-border);
	}

	@media (max-width: 768px) {
		.hero-sphere {
			width: 160px;
			height: 160px;
		}
		.orb-1 { width: 350px; height: 350px; }
		.orb-2 { width: 280px; height: 280px; }
		.orb-3 { width: 240px; height: 240px; }
		.hero-stats {
			padding: 20px 24px;
			gap: 0;
		}
		.stat {
			padding: 0 20px;
		}
		.stat-num { font-size: 22px; }
	}

	@media (max-width: 480px) {
		.hero-actions { flex-direction: column; width: 100%; }
		.btn { width: 100%; }
		.hero-stats {
			display: flex;
			justify-content: center;
			gap: 0;
			padding: 16px 12px;
			width: 100%;
		}
		.stat {
			padding: 0 12px;
			flex: 1;
			min-width: 0;
		}
		.stat-num { font-size: 20px; }
		.stat-label { font-size: 11px; }
		.stat-divider {
			display: block;
			width: 1px;
			height: 28px;
		}
		.hero h1 { font-size: clamp(32px, 9vw, 44px); }
		.hero-desc { font-size: 15px; margin-bottom: 32px; }
		.hero-sphere {
			width: 120px;
			height: 120px;
		}
		.orb { filter: blur(60px); }
		.orb-1 { width: 280px; height: 280px; }
		.orb-2 { width: 220px; height: 220px; }
		.orb-3 { width: 180px; height: 180px; }
	}
</style>

<script>
	const hero = document.getElementById('hero');
	const orbs = document.getElementById('heroOrbs');
	const sphere = document.getElementById('heroSphere');

	if (hero && orbs && sphere) {
		let mouseX = 0, mouseY = 0;
		let currentX = 0, currentY = 0;

		hero.addEventListener('mousemove', (e) => {
			const rect = hero.getBoundingClientRect();
			mouseX = ((e.clientX - rect.left) / rect.width - 0.5) * 2;
			mouseY = ((e.clientY - rect.top) / rect.height - 0.5) * 2;
		});

		function animate() {
			currentX += (mouseX - currentX) * 0.05;
			currentY += (mouseY - currentY) * 0.05;

			const orbEls = orbs!.querySelectorAll('.orb');
			orbEls.forEach((orb, i) => {
				const depth = (i + 1) * 12;
				(orb as HTMLElement).style.transform = `translate(${currentX * depth}px, ${currentY * depth}px)`;
			});

			const sphereDepth = 8;
			if (!sphere) return;
			sphere.style.transform = `scale(${1 + Math.sin(Date.now() * 0.001) * 0.08}) translate(${currentX * sphereDepth}px, ${currentY * sphereDepth}px)`;

			requestAnimationFrame(animate);
		}
		animate();
	}
</script>
