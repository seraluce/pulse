---
---

<section class="hero">
	<div class="container hero-inner">
		<div class="hero-content">
			<div class="hero-badge">专业 · 高效 · 可靠</div>
			<h1>
				用专业方案<br/>
				<span>驱动业务增长</span>
			</h1>
			<p class="hero-desc">
				我们为企业提供全方位的数字化解决方案，从战略规划到落地执行，帮助您在竞争中脱颖而出。
			</p>
			<div class="hero-actions">
				<a href="/contact" class="btn btn-primary">立即咨询</a>
				<a href="/services" class="btn btn-outline">了解更多</a>
			</div>
			<div class="hero-stats">
				<div class="stat">
					<span class="stat-num">500+</span>
					<span class="stat-label">服务客户</span>
				</div>
				<div class="stat-divider"></div>
				<div class="stat">
					<span class="stat-num">98%</span>
					<span class="stat-label">客户满意度</span>
				</div>
				<div class="stat-divider"></div>
				<div class="stat">
					<span class="stat-num">10+</span>
					<span class="stat-label">年行业经验</span>
				</div>
			</div>
		</div>
		<div class="hero-visual">
			<div class="orb orb-1"></div>
			<div class="orb orb-2"></div>
			<div class="orb orb-3"></div>
		</div>
	</div>
</section>

<style>
	.hero {
		min-height: 100dvh;
		display: flex;
		align-items: center;
		padding-top: var(--header-height);
		position: relative;
		overflow: hidden;
	}

	.hero-inner {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 60px;
		align-items: center;
		position: relative;
		z-index: 1;
	}

	.hero-badge {
		display: inline-block;
		padding: 6px 16px;
		font-size: 12px;
		letter-spacing: 0.1em;
		color: var(--color-text-secondary);
		border: 1px solid var(--color-border);
		border-radius: 100px;
		margin-bottom: 24px;
	}

	.hero h1 {
		font-size: clamp(36px, 5vw, 56px);
		font-weight: 700;
		line-height: 1.15;
		letter-spacing: -0.03em;
		margin-bottom: 24px;
	}

	.hero h1 span {
		color: var(--color-text-tertiary);
	}

	.hero-desc {
		font-size: 17px;
		line-height: 1.7;
		color: var(--color-text-secondary);
		max-width: 480px;
		margin-bottom: 36px;
	}

	.hero-actions {
		display: flex;
		gap: 12px;
		margin-bottom: 48px;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 12px 28px;
		font-size: 15px;
		font-weight: 500;
		border-radius: var(--radius);
		transition: all var(--transition-fast);
	}

	.btn-primary {
		background: var(--color-accent);
		color: var(--color-bg);
		border: 1px solid var(--color-accent);
	}

	.btn-primary:hover {
		background: var(--color-accent-hover);
		border-color: var(--color-accent-hover);
	}

	.btn-outline {
		background: transparent;
		color: var(--color-text);
		border: 1px solid var(--color-border);
	}

	.btn-outline:hover {
		border-color: var(--color-text);
	}

	.hero-stats {
		display: flex;
		align-items: center;
		gap: 24px;
	}

	.stat {
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.stat-num {
		font-size: 24px;
		font-weight: 700;
		letter-spacing: -0.02em;
	}

	.stat-label {
		font-size: 13px;
		color: var(--color-text-tertiary);
	}

	.stat-divider {
		width: 1px;
		height: 36px;
		background: var(--color-border);
	}

	/* 模糊光晕 — 桌面端右侧 */
	.hero-visual {
		position: relative;
		width: 100%;
		height: 500px;
	}

	.orb {
		position: absolute;
		border-radius: 50%;
		filter: blur(80px);
		opacity: 0.5;
		will-change: transform;
	}

	.orb-1 {
		width: 320px;
		height: 320px;
		top: 10%;
		left: 15%;
		background: radial-gradient(circle, rgba(160,160,180,0.6) 0%, transparent 70%);
		animation: float-a 14s ease-in-out infinite;
	}

	.orb-2 {
		width: 250px;
		height: 250px;
		top: 40%;
		left: 45%;
		background: radial-gradient(circle, rgba(180,175,170,0.5) 0%, transparent 70%);
		animation: float-b 18s ease-in-out infinite;
	}

	.orb-3 {
		width: 200px;
		height: 200px;
		top: 5%;
		left: 55%;
		background: radial-gradient(circle, rgba(170,170,190,0.4) 0%, transparent 70%);
		animation: float-c 12s ease-in-out infinite;
	}

	:root.dark .orb-1 {
		background: radial-gradient(circle, rgba(80,80,100,0.5) 0%, transparent 70%);
	}
	:root.dark .orb-2 {
		background: radial-gradient(circle, rgba(90,85,80,0.4) 0%, transparent 70%);
	}
	:root.dark .orb-3 {
		background: radial-gradient(circle, rgba(70,70,90,0.35) 0%, transparent 70%);
	}

	@keyframes float-a {
		0%, 100% { transform: translate(0, 0) scale(1); }
		25% { transform: translate(30px, -20px) scale(1.05); }
		50% { transform: translate(-15px, 25px) scale(0.95); }
		75% { transform: translate(20px, 15px) scale(1.02); }
	}

	@keyframes float-b {
		0%, 100% { transform: translate(0, 0) scale(1); }
		33% { transform: translate(-25px, 20px) scale(1.08); }
		66% { transform: translate(20px, -15px) scale(0.96); }
	}

	@keyframes float-c {
		0%, 100% { transform: translate(0, 0) scale(1); }
		50% { transform: translate(-20px, 30px) scale(1.1); }
	}

	/* 移动端：光晕作为全屏背景 */
	@media (max-width: 900px) {
		.hero-inner {
			grid-template-columns: 1fr;
			text-align: center;
		}
		.hero-desc { margin-left: auto; margin-right: auto; margin-bottom: 28px; }
		.hero-actions { justify-content: center; margin-bottom: 36px; }
		.hero-stats { justify-content: center; }

		.hero-visual {
			position: absolute;
			inset: 0;
			height: auto;
			z-index: 0;
			pointer-events: none;
		}

		.orb-1 {
			width: 350px;
			height: 350px;
			top: 15%;
			left: 10%;
		}
		.orb-2 {
			width: 280px;
			height: 280px;
			top: 45%;
			left: 50%;
		}
		.orb-3 {
			width: 220px;
			height: 220px;
			top: 10%;
			left: 60%;
		}
	}

	@media (max-width: 480px) {
		.hero-actions { flex-direction: column; }
		.hero-stats { flex-wrap: wrap; gap: 16px; }
		.hero h1 { font-size: clamp(28px, 8vw, 40px); }
		.hero-desc { font-size: 15px; }

		.orb { filter: blur(60px); }
		.orb-1 { width: 260px; height: 260px; }
		.orb-2 { width: 200px; height: 200px; }
		.orb-3 { width: 160px; height: 160px; }
	}
</style>
