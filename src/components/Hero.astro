---
---

<section class="hero">
	<div class="container hero-inner">
		<div class="hero-content">
			<div class="hero-badge">专业 · 高效 · 可靠</div>
			<h1>
				用专业方案<br/>
				<span>驱动业务增长</span>
			</h1>
			<p class="hero-desc">
				我们为企业提供全方位的数字化解决方案，从战略规划到落地执行，帮助您在竞争中脱颖而出。
			</p>
			<div class="hero-actions">
				<a href="#contact" class="btn btn-primary">立即咨询</a>
				<a href="#features" class="btn btn-outline">了解更多</a>
			</div>
			<div class="hero-stats">
				<div class="stat">
					<span class="stat-num">500+</span>
					<span class="stat-label">服务客户</span>
				</div>
				<div class="stat-divider"></div>
				<div class="stat">
					<span class="stat-num">98%</span>
					<span class="stat-label">客户满意度</span>
				</div>
				<div class="stat-divider"></div>
				<div class="stat">
					<span class="stat-num">10+</span>
					<span class="stat-label">年行业经验</span>
				</div>
			</div>
		</div>
		<div class="hero-visual">
			<div class="hero-graphic">
				<div class="line-ring ring-1"></div>
				<div class="line-ring ring-2"></div>
				<div class="line-ring ring-3"></div>
				<div class="line-dot dot-1"></div>
				<div class="line-dot dot-2"></div>
				<div class="line-dot dot-3"></div>
				<div class="line-dot dot-4"></div>
			</div>
		</div>
	</div>
</section>

<style>
	.hero {
		min-height: 100vh;
		display: flex;
		align-items: center;
		padding-top: var(--header-height);
		overflow: hidden;
	}

	.hero-inner {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 60px;
		align-items: center;
	}

	.hero-badge {
		display: inline-block;
		padding: 6px 16px;
		font-size: 12px;
		letter-spacing: 0.1em;
		color: var(--color-text-secondary);
		border: 1px solid var(--color-border);
		border-radius: 100px;
		margin-bottom: 24px;
	}

	.hero h1 {
		font-size: clamp(36px, 5vw, 56px);
		font-weight: 700;
		line-height: 1.15;
		letter-spacing: -0.03em;
		margin-bottom: 24px;
	}

	.hero h1 span {
		color: var(--color-text-tertiary);
	}

	.hero-desc {
		font-size: 17px;
		line-height: 1.7;
		color: var(--color-text-secondary);
		max-width: 480px;
		margin-bottom: 36px;
	}

	.hero-actions {
		display: flex;
		gap: 12px;
		margin-bottom: 48px;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 12px 28px;
		font-size: 15px;
		font-weight: 500;
		border-radius: var(--radius);
		transition: all var(--transition);
	}

	.btn-primary {
		background: var(--color-accent);
		color: var(--color-bg);
		border: 1px solid var(--color-accent);
	}

	.btn-primary:hover {
		background: var(--color-accent-hover);
		border-color: var(--color-accent-hover);
	}

	.btn-outline {
		background: transparent;
		color: var(--color-text);
		border: 1px solid var(--color-border);
	}

	.btn-outline:hover {
		border-color: var(--color-text);
	}

	.hero-stats {
		display: flex;
		align-items: center;
		gap: 24px;
	}

	.stat {
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.stat-num {
		font-size: 24px;
		font-weight: 700;
		letter-spacing: -0.02em;
	}

	.stat-label {
		font-size: 13px;
		color: var(--color-text-tertiary);
	}

	.stat-divider {
		width: 1px;
		height: 36px;
		background: var(--color-border);
	}

	/* 线条装饰图形 */
	.hero-visual {
		display: flex;
		justify-content: center;
		align-items: center;
	}

	.hero-graphic {
		position: relative;
		width: 400px;
		height: 400px;
	}

	.line-ring {
		position: absolute;
		border-radius: 50%;
		border: 1px solid var(--color-border);
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
	}

	.ring-1 {
		width: 200px;
		height: 200px;
		border-color: var(--color-border);
	}

	.ring-2 {
		width: 300px;
		height: 300px;
		border-color: var(--color-border-light);
	}

	.ring-3 {
		width: 400px;
		height: 400px;
		border-color: var(--color-border-light);
		opacity: 0.5;
	}

	.line-dot {
		position: absolute;
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--color-text);
	}

	.dot-1 { top: 50%; left: 50%; transform: translate(-50%, -50%); }
	.dot-2 { top: 0; left: 50%; transform: translate(-50%, -50%); }
	.dot-3 { top: 50%; right: 0; transform: translate(50%, -50%); }
	.dot-4 { bottom: 0; left: 50%; transform: translate(-50%, 50%); }

	:root.dark .line-dot {
		background: var(--color-text);
	}

	@media (max-width: 900px) {
		.hero-inner {
			grid-template-columns: 1fr;
			text-align: center;
		}
		.hero-desc { margin-left: auto; margin-right: auto; }
		.hero-actions { justify-content: center; }
		.hero-stats { justify-content: center; }
		.hero-visual { display: none; }
	}

	@media (max-width: 480px) {
		.hero-actions { flex-direction: column; }
		.hero-stats { flex-wrap: wrap; gap: 16px; }
	}
</style>
