---

<section class="hero">
	<div class="container hero-inner">
		<div class="hero-content">
			<div class="hero-badge">专业 · 高效 · 可靠</div>
			<h1>
				用专业方案<br/>
				<span>驱动业务增长</span>
			</h1>
			<p class="hero-desc">
				我们为企业提供全方位的数字化解决方案，从战略规划到落地执行，帮助您在竞争中脱颖而出。
			</p>
			<div class="hero-actions">
				<a href="/contact" class="btn btn-primary">立即咨询</a>
				<a href="/services" class="btn btn-outline">了解更多</a>
			</div>
			<div class="hero-stats">
				<div class="stat">
					<span class="stat-num">500+</span>
					<span class="stat-label">服务客户</span>
				</div>
				<div class="stat-divider"></div>
				<div class="stat">
					<span class="stat-num">98%</span>
					<span class="stat-label">客户满意度</span>
				</div>
				<div class="stat-divider"></div>
				<div class="stat">
					<span class="stat-num">10+</span>
					<span class="stat-label">年行业经验</span>
				</div>
			</div>
		</div>
		<div class="hero-visual">
			<div class="hero-graphic">
				<div class="ripple ripple-1"></div>
				<div class="ripple ripple-2"></div>
				<div class="ripple ripple-3"></div>
				<div class="ripple ripple-4"></div>
				<div class="ripple-core"></div>
			</div>
		</div>
	</div>
</section>

<style>
	.hero {
		min-height: 100dvh;
		display: flex;
		align-items: center;
		padding-top: var(--header-height);
		overflow: hidden;
	}

	.hero-inner {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 60px;
		align-items: center;
	}

	.hero-badge {
		display: inline-block;
		padding: 6px 16px;
		font-size: 12px;
		letter-spacing: 0.1em;
		color: var(--color-text-secondary);
		border: 1px solid var(--color-border);
		border-radius: 100px;
		margin-bottom: 24px;
	}

	.hero h1 {
		font-size: clamp(36px, 5vw, 56px);
		font-weight: 700;
		line-height: 1.15;
		letter-spacing: -0.03em;
		margin-bottom: 24px;
	}

	.hero h1 span {
		color: var(--color-text-tertiary);
	}

	.hero-desc {
		font-size: 17px;
		line-height: 1.7;
		color: var(--color-text-secondary);
		max-width: 480px;
		margin-bottom: 36px;
	}

	.hero-actions {
		display: flex;
		gap: 12px;
		margin-bottom: 48px;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 12px 28px;
		font-size: 15px;
		font-weight: 500;
		border-radius: var(--radius);
		transition: all var(--transition-fast);
	}

	.btn-primary {
		background: var(--color-accent);
		color: var(--color-bg);
		border: 1px solid var(--color-accent);
	}

	.btn-primary:hover {
		background: var(--color-accent-hover);
		border-color: var(--color-accent-hover);
	}

	.btn-outline {
		background: transparent;
		color: var(--color-text);
		border: 1px solid var(--color-border);
	}

	.btn-outline:hover {
		border-color: var(--color-text);
	}

	.hero-stats {
		display: flex;
		align-items: center;
		gap: 24px;
	}

	.stat {
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.stat-num {
		font-size: 24px;
		font-weight: 700;
		letter-spacing: -0.02em;
	}

	.stat-label {
		font-size: 13px;
		color: var(--color-text-tertiary);
	}

	.stat-divider {
		width: 1px;
		height: 36px;
		background: var(--color-border);
	}

	/* 涟漪动画图形 */
	.hero-visual {
		display: flex;
		justify-content: center;
		align-items: center;
	}

	.hero-graphic {
		position: relative;
		width: 320px;
		height: 320px;
	}

	.ripple {
		position: absolute;
		top: 50%;
		left: 50%;
		width: 20px;
		height: 20px;
		border-radius: 50%;
		border: 1.5px solid var(--color-border);
		transform: translate(-50%, -50%);
		opacity: 0;
		animation: ripple-expand 4s cubic-bezier(0, 0.2, 0.8, 1) infinite;
	}

	.ripple-1 { animation-delay: 0s; }
	.ripple-2 { animation-delay: 1s; }
	.ripple-3 { animation-delay: 2s; }
	.ripple-4 { animation-delay: 3s; }

	@keyframes ripple-expand {
		0% {
			width: 20px;
			height: 20px;
			opacity: 0.6;
			border-width: 2px;
		}
		100% {
			width: 320px;
			height: 320px;
			opacity: 0;
			border-width: 0.5px;
		}
	}

	.ripple-core {
		position: absolute;
		top: 50%;
		left: 50%;
		width: 12px;
		height: 12px;
		border-radius: 50%;
		background: var(--color-text);
		transform: translate(-50%, -50%);
		animation: core-pulse 2s ease-in-out infinite;
	}

	@keyframes core-pulse {
		0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
		50% { transform: translate(-50%, -50%) scale(1.3); opacity: 0.7; }
	}

	@media (max-width: 900px) {
		.hero-inner {
			grid-template-columns: 1fr;
			text-align: center;
		}
		.hero-desc { margin-left: auto; margin-right: auto; margin-bottom: 28px; }
		.hero-actions { justify-content: center; margin-bottom: 36px; }
		.hero-stats { justify-content: center; }

		/* 移动端涟漪放到底部 */
		.hero-visual {
			position: absolute;
			bottom: 0;
			left: 50%;
			transform: translateX(-50%);
			width: 100%;
			pointer-events: none;
		}

		.hero-graphic {
			width: 240px;
			height: 240px;
		}

		.ripple {
			border-color: var(--color-border-light);
		}

		@keyframes ripple-expand {
			0% {
				width: 16px;
				height: 16px;
				opacity: 0.4;
				border-width: 1.5px;
			}
			100% {
				width: 240px;
				height: 240px;
				opacity: 0;
				border-width: 0.3px;
			}
		}

		.ripple-core {
			width: 8px;
			height: 8px;
			opacity: 0.5;
		}
	}

	@media (max-width: 480px) {
		.hero-actions { flex-direction: column; }
		.hero-stats { flex-wrap: wrap; gap: 16px; }
		.hero h1 { font-size: clamp(28px, 8vw, 40px); }
		.hero-desc { font-size: 15px; }

		.hero-graphic {
			width: 180px;
			height: 180px;
		}

		@keyframes ripple-expand {
			0% {
				width: 12px;
				height: 12px;
				opacity: 0.35;
			}
			100% {
				width: 180px;
				height: 180px;
				opacity: 0;
			}
		}
	}
</style>
