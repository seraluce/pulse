---
import { site } from '../config';
const about = site.about;
---

<section id="about" class="about section">
	<div class="container">
		<div class="about-grid">
			<div class="about-content animate-on-scroll">
				<span class="section-tag">{about.header.tag}</span>
				<h2>{about.header.title}</h2>
				<p class="about-lead">{about.description}</p>
				<div class="about-highlights">
					{about.highlights.map((h) => (
						<span class="about-highlight">{h}</span>
					))}
				</div>
				<a href={about.ctaHref} class="about-link">{about.ctaText}</a>
			</div>
			<div class="about-timeline animate-on-scroll delay-2">
				<div class="timeline-line"></div>
				{about.milestones.map((m) => (
					<div class="timeline-item">
						<div class="timeline-dot"></div>
						<div class="timeline-year">{m.year}</div>
						<div class="timeline-title">{m.title}</div>
						<div class="timeline-text">{m.desc}</div>
					</div>
				))}
			</div>
		</div>
	</div>
</section>

<style>
	.about {
		background: var(--color-bg);
	}

	.about-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 80px;
		align-items: start;
	}

	.section-tag {
		display: inline-block;
		font-size: 12px;
		letter-spacing: 0.15em;
		color: var(--color-text-tertiary);
		margin-bottom: 16px;
		text-transform: uppercase;
	}

	.about-content h2 {
		font-size: clamp(28px, 3.5vw, 40px);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin-bottom: 24px;
	}

	.about-lead {
		font-size: 18px;
		line-height: 1.7;
		color: var(--color-text);
		margin-bottom: 20px;
		font-weight: 500;
	}

	.about-text {
		font-size: 15px;
		line-height: 1.8;
		color: var(--color-text-secondary);
		margin-bottom: 16px;
	}

	.about-link {
		display: inline-block;
		font-size: 14px;
		font-weight: 500;
		color: var(--color-text);
		margin-top: 8px;
		border-bottom: 1px solid var(--color-border);
		padding-bottom: 2px;
		transition: border-color var(--transition-fast);
	}

	.about-link:hover {
		border-color: var(--color-text);
	}

	.about-timeline {
		position: relative;
		padding-left: 32px;
	}

	.timeline-line {
		position: absolute;
		left: 4px;
		top: 8px;
		bottom: 8px;
		width: 1px;
		background: var(--color-border);
	}

	.timeline-item {
		position: relative;
		padding-bottom: 36px;
	}

	.timeline-item:last-child {
		padding-bottom: 0;
	}

	.timeline-dot {
		position: absolute;
		left: -32px;
		top: 6px;
		width: 9px;
		height: 9px;
		border-radius: 50%;
		border: 2px solid var(--color-text);
		background: var(--color-bg);
	}

	.timeline-year {
		font-size: 13px;
		font-weight: 600;
		color: var(--color-text-tertiary);
		letter-spacing: 0.05em;
		margin-bottom: 6px;
	}

	.timeline-text {
		font-size: 15px;
		color: var(--color-text-secondary);
		line-height: 1.6;
	}

	.timeline-title {
		font-size: 15px;
		font-weight: 600;
		color: var(--color-text);
		margin-bottom: 4px;
	}

	.about-highlights {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-bottom: 24px;
	}

	.about-highlight {
		font-size: 13px;
		font-weight: 500;
		padding: 6px 14px;
		border-radius: 20px;
		background: var(--color-bg-secondary);
		color: var(--color-text);
	}

	@media (max-width: 900px) {
		.about-grid {
			grid-template-columns: 1fr;
			gap: 48px;
		}
	}
</style>
