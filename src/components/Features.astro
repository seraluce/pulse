---
import { site } from '../config';
const header = site.features.header;
const features = site.features.items;
const iconMap = site.icons.features;
---

<section id="features" class="features section">
	<div class="container">
		<div class="section-header animate-on-scroll">
			<span class="section-tag">{header.tag}</span>
			<h2>{header.title}</h2>
			{header.subtitle && <p>{header.subtitle}</p>}
		</div>
		<div class="features-grid">
			{features.map((f, i) => (
				<div class={`feature-card animate-on-scroll delay-${i % 3 + 1}`}>
					<div class="feature-icon" set:html={`<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">${iconMap[f.icon]}</svg>`}></div>
					<h3>{f.title}</h3>
					<p>{f.desc}</p>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.features {
		background: var(--color-bg-secondary);
	}

	.section-header {
		text-align: center;
		margin-bottom: 64px;
	}

	.section-tag {
		display: inline-block;
		font-size: 12px;
		letter-spacing: 0.15em;
		color: var(--color-text-tertiary);
		margin-bottom: 16px;
		text-transform: uppercase;
	}

	.section-header h2 {
		font-size: clamp(28px, 3.5vw, 40px);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin-bottom: 12px;
	}

	.section-header p {
		font-size: 16px;
		color: var(--color-text-secondary);
	}

	.features-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1px;
		background: var(--color-border);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		overflow: hidden;
	}

	.feature-card {
		background: var(--color-card-bg-gradient);
		padding: 40px 32px;
		transition: background var(--transition-fast), box-shadow var(--transition-fast), transform var(--transition-fast);
		position: relative;
		overflow: hidden;
	}

	.feature-card::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 3px;
		background: linear-gradient(90deg, transparent, var(--color-highlight), transparent);
		opacity: 0;
		transition: opacity var(--transition-fast);
	}

	.feature-card:hover {
		background: var(--color-card-bg-hover);
		box-shadow: 0 8px 32px var(--color-card-shadow-hover), 0 0 0 1px var(--color-card-glow);
		transform: translateY(-2px);
	}

	.feature-card:hover::before {
		opacity: 1;
	}

	.feature-icon {
		width: 48px;
		height: 48px;
		display: flex;
		align-items: center;
		justify-content: center;
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		margin-bottom: 20px;
		color: var(--color-text);
		background: var(--color-card-bg-gradient);
		box-shadow: 0 2px 8px var(--color-card-shadow);
		transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
	}

	.feature-card:hover .feature-icon {
		border-color: var(--color-highlight);
		box-shadow: 0 4px 16px var(--color-card-glow);
	}

	.feature-card h3 {
		font-size: 17px;
		font-weight: 600;
		margin-bottom: 8px;
		letter-spacing: -0.01em;
	}

	.feature-card p {
		font-size: 14px;
		line-height: 1.7;
		color: var(--color-text-secondary);
	}

	@media (max-width: 900px) {
		.features-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 560px) {
		.features-grid {
			grid-template-columns: 1fr;
		}
		.feature-card {
			padding: 28px 24px;
		}
	}
</style>
