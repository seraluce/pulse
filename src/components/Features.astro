---
import { site } from '../config';
const header = site.features.header;
const features = site.features.items;
const iconMap = site.icons.features;
---

<section id="features" class="features section">
	<div class="container">
		<div class="section-header animate-on-scroll">
			<span class="section-tag">{header.tag}</span>
			<h2>{header.title}</h2>
			{header.subtitle && <p>{header.subtitle}</p>}
		</div>
		<div class="features-grid">
			{features.map((f, i) => (
				<div class={`feature-card animate-on-scroll delay-${i % 3 + 1}`}>
					<div class="feature-icon" set:html={`<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">${iconMap[f.icon]}</svg>`}></div>
					<h3>{f.title}</h3>
					<p>{f.desc}</p>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.features {
		background: var(--color-bg-secondary);
	}

	.section-header {
		text-align: center;
		margin-bottom: 64px;
	}

	.section-tag {
		display: inline-block;
		font-size: 12px;
		letter-spacing: 0.15em;
		color: var(--color-text-tertiary);
		margin-bottom: 16px;
		text-transform: uppercase;
	}

	.section-header h2 {
		font-size: clamp(28px, 3.5vw, 40px);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin-bottom: 12px;
	}

	.section-header p {
		font-size: 16px;
		color: var(--color-text-secondary);
	}

	.features-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 24px;
	}

	.feature-card {
		background: var(--color-card-bg-gradient);
		padding: 48px 36px;
		border-radius: var(--radius-lg);
		border: 1px solid var(--color-border);
		transition: background var(--transition-fast), box-shadow var(--transition-fast), transform var(--transition-fast), border-color var(--transition-fast);
		position: relative;
		overflow: hidden;
	}

	.feature-card::before {
		content: "";
		position: absolute;
		top: -40%;
		right: -30%;
		width: 120%;
		height: 100%;
		background: radial-gradient(ellipse at 70% 30%, var(--card-accent, var(--color-card-glow)) 0%, transparent 55%);
		opacity: 0;
		transition: opacity var(--transition-slow);
		pointer-events: none;
	}

	.feature-card::after {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 2px;
		background: var(--card-accent-line, var(--color-highlight));
		opacity: 0;
		transition: opacity var(--transition-fast);
	}

	.feature-card:nth-child(1) { --card-accent: rgba(59, 130, 246, 0.1); --card-accent-line: #3b82f6; }
	.feature-card:nth-child(2) { --card-accent: rgba(139, 92, 246, 0.1); --card-accent-line: #8b5cf6; }
	.feature-card:nth-child(3) { --card-accent: rgba(6, 182, 212, 0.1); --card-accent-line: #06b6d4; }
	.feature-card:nth-child(4) { --card-accent: rgba(245, 158, 11, 0.1); --card-accent-line: #f59e0b; }
	.feature-card:nth-child(5) { --card-accent: rgba(16, 185, 129, 0.1); --card-accent-line: #10b981; }
	.feature-card:nth-child(6) { --card-accent: rgba(236, 72, 153, 0.1); --card-accent-line: #ec4899; }

	.feature-card:hover {
		background: var(--color-card-bg-hover);
		box-shadow: 0 12px 40px var(--color-card-shadow-hover), 0 0 0 1px var(--card-accent, var(--color-card-glow));
		transform: translateY(-3px);
		border-color: var(--card-accent-line, var(--color-highlight));
	}

	.feature-card:hover::before {
		opacity: 1;
	}

	.feature-card:hover::after {
		opacity: 1;
	}

	.feature-icon {
		width: 52px;
		height: 52px;
		display: flex;
		align-items: center;
		justify-content: center;
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		margin-bottom: 22px;
		color: var(--color-text);
		background: var(--color-card-bg-gradient);
		box-shadow: 0 2px 8px var(--color-card-shadow);
		transition: border-color var(--transition-fast), box-shadow var(--transition-fast), color var(--transition-fast), transform var(--transition-fast);
		position: relative;
		z-index: 1;
	}

	.feature-card:hover .feature-icon {
		border-color: var(--card-accent-line, var(--color-highlight));
		box-shadow: 0 4px 16px var(--card-accent, var(--color-card-glow));
		color: var(--card-accent-line, var(--color-highlight));
		transform: scale(1.05);
	}

	.feature-card h3 {
		font-size: 17px;
		font-weight: 600;
		margin-bottom: 8px;
		letter-spacing: -0.01em;
	}

	.feature-card p {
		font-size: 14px;
		line-height: 1.7;
		color: var(--color-text-secondary);
	}

	@media (max-width: 900px) {
		.features-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 560px) {
		.features-grid {
			grid-template-columns: 1fr;
		}
		.feature-card {
			padding: 28px 24px;
		}
	}
</style>
